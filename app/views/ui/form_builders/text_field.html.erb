<% set_meta_tags(
  title: "TextField - Rails UI Components",
  description: "Text input fields with support for various HTML5 types, sizes, labels, hints, and validation.",
  keywords: "Rails, UI Components, Form Builder, TextField"
) %>
<% breadcrumb :ui_form_builders_text_field %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "TextField" %>
    <%= ui.header_subtitle "Text input fields with support for various HTML5 types, sizes, labels, hints, and validation." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/lib/form_builders/fields/text.rb", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("text_field") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("text_field") %>
  </section>

  <%= render_props_table("text_field") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("text_field") %>
  </section>
</article>
