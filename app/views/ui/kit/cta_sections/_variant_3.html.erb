<%# Variant 3: Split CTA — text on left, email input + button on right %>
<section class="bg-background py-16 lg:py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col items-center gap-10 lg:flex-row lg:justify-between">
      <div class="max-w-xl text-center lg:text-left">
        <h2 class="text-foreground text-3xl font-bold tracking-tight sm:text-4xl">
          Stay ahead of the curve
        </h2>
        <p class="text-muted-foreground mt-4 text-lg leading-relaxed">
          Get weekly insights on product development, design systems, and engineering best practices delivered straight to your inbox.
        </p>
      </div>
      <div class="w-full max-w-md">
        <%= form_with url: root_path, class: "!gap-0" do |f| %>
          <%= ui.group do %>
            <%= f.email_field :email, label: false, placeholder: "Enter your email" %>
            <%= ui.btn size: :lg do %>
              Subscribe
              <%= ui.icon "envelope", size: 5 %>
            <% end %>
          <% end %>
        <% end %>
        <p class="text-muted-foreground mt-3 text-sm">
          We respect your privacy. Unsubscribe at any time.
        </p>
      </div>
    </div>
  </div>
</section>
