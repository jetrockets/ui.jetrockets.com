<%
  set_meta_tags(
    title: "Clipboard - Rails UI Components",
    description: "Clipboard component for copying content to clipboard.",
    keywords: "Rails, UI Components, Clipboard"
  )
%>
<% breadcrumb :ui_clipboard %>

<article>
  <%= ui.header do %>
    <%= ui.header_heading do %>
      <%= ui.header_title "Clipboard" %>
      <%= ui.header_subtitle "Clipboard component for copying content to clipboard." %>
    <% end %>
    <%= ui.header_actions do %>
      <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/clipboard", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
    <% end %>
  <% end %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Example</h2>
    <%= ui.tabs do %>
      <%= ui.tabs_item "Preview", href: ui_clipboard_path, active: !params[:code] %>
      <%= ui.tabs_item "Code", href: ui_clipboard_path(code: true), active: params[:code] %>
    <% end %>

    <div class="flex flex-col gap-2">
      <% unless params[:code] %>
        <%= render "ui/examples/clipboard" %>
      <% else %>
        <%= render_code_example("ui/examples/_clipboard") %>
      <% end %>
    </div>
  </section>
</article>
