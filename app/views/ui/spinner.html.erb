<% set_meta_tags(
  title: "Spinner - Rails UI Components",
  description: "Spinner component for loading indicators.",
  keywords: "Rails, UI Components, Spinner, Loading Indicator, Turbo Frame"
) %>
<% breadcrumb :ui_spinner %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Spinner" %>
    <%= ui.header_subtitle "Spinner component for loading indicators." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/spinner", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("spinner") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("spinner") %>
  </section>

  <%= render_content_info("spinner") %>
  <%= render_props_table("spinner") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("spinner") %>
  </section>
</article>
