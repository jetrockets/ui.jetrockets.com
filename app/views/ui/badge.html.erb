<%
  set_meta_tags(
    title: "Badge - Rails UI Components",
    description: "Badge component for displaying status and labels.",
    keywords: "Rails, UI Components, Badge"
  )
%>
<% breadcrumb :ui_avatar %>

<article>
  <%= ui.header do %>
    <%= ui.header_heading do %>
      <%= ui.header_title "Badge" %>
      <%= ui.header_subtitle "Badge component for displaying status and labels." %>
    <% end %>
    <%= ui.header_actions do %>
      <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/badge", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
    <% end %>
  <% end %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Example</h2>
    <%= ui.tabs do %>
      <%= ui.tabs_item "Preview", href: ui_badge_path, active: !params[:code] %>
      <%= ui.tabs_item "Code", href: ui_badge_path(code: true), active: params[:code] %>
    <% end %>

    <div class="flex flex-col gap-2">
      <% unless params[:code] %>
        <%= render "ui/examples/badge" %>
      <% else %>
        <%= render_code_example("ui/examples/_badge") %>
      <% end %>
    </div>
  </section>
</article>
