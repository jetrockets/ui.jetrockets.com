<%
  set_meta_tags(
    title: "Popover - Rails UI Components",
    description: "Popover component for contextual content overlays.",
    keywords: "Rails, UI Components, Popover"
  )
%>
<% breadcrumb :ui_popover %>

<article>
  <%= ui.header do %>
    <%= ui.header_heading do %>
      <%= ui.header_title "Popover" %>
      <%= ui.header_subtitle "Popover component for contextual content overlays." %>
    <% end %>
    <%= ui.header_actions do %>
      <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/popover", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
    <% end %>
  <% end %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Example</h2>
    <%= ui.tabs do %>
      <%= ui.tabs_item "Preview", href: ui_popover_path, active: !params[:code] %>
      <%= ui.tabs_item "Code", href: ui_popover_path(code: true), active: params[:code] %>
    <% end %>

    <div class="flex flex-col gap-2">
      <% unless params[:code] %>
        <%= render "ui/examples/popover" %>
      <% else %>
        <%= render_code_example("ui/examples/_popover") %>
      <% end %>
    </div>
  </section>
</article>
