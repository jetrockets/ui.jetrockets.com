<%
  set_meta_tags(
    title: "Theme Builder - Rails UI Components",
    description: "Create custom themes for your project"
  )

  # Build defaults hash from all editable color vars
  defaults = {}
  @theme[:hex].each do |key, value|
    defaults[key.tr("-", "_")] = value
  end
  # Alpha values (only for vars that have opacity)
  alphas = {}
  @theme[:alpha].each do |key, value|
    k = key.tr("-", "_")
    alphas[k] = value
    defaults["#{k}_alpha".to_sym] = value
  end
  defaults[:radius_base] = @theme[:radius_base]
  defaults[:radius_btn] = @theme[:radius_btn]
  defaults[:radius_form] = @theme[:radius_form]

  # Color groups for sidebar accordion sections
  color_groups = [
    { title: "Primary", vars: [
      { name: "primary", label: "Background" },
      { name: "primary-foreground", label: "Foreground" }
    ]},
    { title: "Secondary", vars: [
      { name: "secondary", label: "Background" },
      { name: "secondary-foreground", label: "Foreground" }
    ]},
    { title: "Accent", vars: [
      { name: "accent", label: "Background" },
      { name: "accent-foreground", label: "Foreground" }
    ]},
    { title: "Background", vars: [
      { name: "background", label: "Background" },
      { name: "foreground", label: "Foreground" }
    ]},
    { title: "Card", vars: [
      { name: "card", label: "Background" },
      { name: "card-foreground", label: "Foreground" }
    ]},
    { title: "Muted", vars: [
      { name: "muted", label: "Background" },
      { name: "muted-foreground", label: "Foreground" }
    ]},
    { title: "Border & Input", vars: [
      { name: "border", label: "Border" },
      { name: "input", label: "Input" },
      { name: "input-focus", label: "Focus" },
      { name: "input-ring", label: "Ring" }
    ]},
    { title: "Status", vars: [
      { name: "destructive", label: "Destructive" },
      { name: "success", label: "Success" },
      { name: "warning", label: "Warning" },
      { name: "info", label: "Info" }
    ]}
  ]
%>

<div class="min-h-screen"
     data-controller="builder"
     data-builder-defaults-value="<%= defaults.to_json %>"
     data-builder-download-url-value="<%= builder_download_path %>">

  <%# Two-column layout: sidebar + preview %>
  <div class="flex min-h-screen">

    <%# ========================================= %>
    <%# Left sidebar — theme controls             %>
    <%# ========================================= %>
    <aside class="w-72 shrink-0 border-r border-border bg-muted overflow-y-auto sticky top-0 h-screen flex flex-col">
      <%# Sidebar header %>
      <div class="px-4 py-3 border-b border-border flex items-center justify-between sticky top-0 bg-muted z-10">
        <h1 class="text-base font-semibold">Theme Builder</h1>
        <div class="flex items-center gap-1">
          <%= ui.btn variant: :secondary, size: :icon_sm, circle: true, data: { action: "click->builder#toggleTheme" } do %>
            <%= ui.icon "sun", size: 3.5, data: { builder_target: "lightIcon" }, class: "hidden" %>
            <%= ui.icon "moon", size: 3.5, data: { builder_target: "darkIcon" } %>
          <% end %>
        </div>
      </div>

      <div class="divide-y divide-border flex-1">
        <%# ---- Colors ---- %>
        <% color_groups.each_with_index do |group, gi| %>
          <%= ui.accordion name: "builder", open: gi == 0 do %>
            <%= ui.accordion_summary class: "px-4 text-xs" do %>
              <%= group[:title] %>
            <% end %>
            <%= ui.accordion_body class: "px-4 pb-3" do %>
              <div class="flex flex-col gap-3">
                <% group[:vars].each do |var| %>
                  <% param_key = var[:name].tr("-", "_") %>
                  <% light_hex = defaults[param_key] %>
                  <% dark_hex = defaults["#{param_key}_dark"] %>
                  <% light_alpha = alphas[param_key] %>
                  <% dark_alpha = alphas["#{param_key}_dark"] %>
                  <% next unless light_hex %>

                  <%# Light row %>
                  <div data-builder-target="colorRow"
                       data-color-var="<%= var[:name] %>"
                       data-color-mode="light">
                    <span class="text-[10px] text-muted-foreground"><%= var[:label] %></span>
                    <div class="flex items-center gap-1.5">
                      <input autocomplete="off" type="color" value="<%= light_hex %>"
                             class="size-10 shrink-0 rounded cursor-pointer"
                             data-action="input->builder#updateColor">
                      <input autocomplete="off" type="text" value="<%= light_hex %>"
                             class="form__field !py-0.5 !text-xs flex-1 font-mono"
                             data-action="change->builder#updateColor">
                      <% if light_alpha %>
                        <input autocomplete="off" type="number" value="<%= light_alpha %>"
                               min="0" max="100" step="5"
                               class="form__field !py-0.5 !text-xs w-16 shrink-0 font-mono text-center"
                               data-role="alpha"
                               data-action="change->builder#updateColor">
                      <% end %>
                    </div>
                  </div>

                  <%# Dark row %>
                  <% if dark_hex %>
                    <div class="hidden"
                         data-builder-target="colorRow"
                         data-color-var="<%= var[:name] %>"
                         data-color-mode="dark">
                      <span class="text-[10px] text-muted-foreground"><%= var[:label] %></span>
                      <div class="flex items-center gap-1.5">
                        <input autocomplete="off" type="color" value="<%= dark_hex %>"
                               class="size-10 shrink-0 rounded cursor-pointer"
                               data-action="input->builder#updateColor">
                        <input autocomplete="off" type="text" value="<%= dark_hex %>"
                               class="form__field !py-0.5 !text-xs flex-1 font-mono"
                               data-action="change->builder#updateColor">
                        <% if dark_alpha %>
                          <input autocomplete="off" type="number" value="<%= dark_alpha %>"
                                 min="0" max="100" step="5"
                                 class="form__field !py-0.5 !text-xs w-16 shrink-0 font-mono text-center"
                                 data-role="alpha"
                                 data-action="change->builder#updateColor">
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          <% end %>
        <% end %>

        <%# ---- Radius ---- %>
        <%= ui.accordion name: "builder" do %>
          <%= ui.accordion_summary class: "px-4 text-xs" do %>
            Radius
          <% end %>
          <%= ui.accordion_body class: "px-4 pb-3" do %>
            <div class="flex flex-col gap-3">
              <div>
                <span class="text-[10px] text-muted-foreground mb-1 block">Base</span>
                <div class="ui_group ui_group-sticky">
                  <% %w[none sm md lg xl].each do |size| %>
                    <%= ui.btn size.upcase, size: :xs, variant: defaults[:radius_base] == size ? :default : :outline,
                        data: { builder_target: "radiusBase", action: "click->builder#updateRadiusBase", value: size } %>
                  <% end %>
                </div>
              </div>
              <div>
                <span class="text-[10px] text-muted-foreground mb-1 block">Buttons</span>
                <div class="ui_group ui_group-sticky">
                  <% %w[none sm md lg xl full].each do |size| %>
                    <%= ui.btn size.upcase, size: :xs, variant: (defaults[:radius_btn] || defaults[:radius_base]) == size ? :default : :outline,
                        data: { builder_target: "radiusBtn", action: "click->builder#updateRadiusBtn", value: size } %>
                  <% end %>
                </div>
              </div>
              <div>
                <span class="text-[10px] text-muted-foreground mb-1 block">Form fields</span>
                <div class="ui_group ui_group-sticky">
                  <% %w[none sm md lg full].each do |size| %>
                    <%= ui.btn size.upcase, size: :xs, variant: defaults[:radius_form] == size ? :default : :outline,
                        data: { builder_target: "radiusForm", action: "click->builder#updateRadiusForm", value: size } %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>

      </div>

      <%# Sidebar footer — actions %>
      <div class="px-4 py-3 border-t border-border flex items-center justify-between gap-2 sticky bottom-0 bg-muted">
        <%= ui.btn "Download CSS", variant: :default, size: :sm, url: builder_download_path, data: { builder_target: "download" } %>
        <%= ui.btn "Reset", variant: :ghost, size: :sm, data: { action: "click->builder#reset" } %>
      </div>
    </aside>

    <%# ========================================= %>
    <%# Right side — preview                      %>
    <%# ========================================= %>
    <main class="flex-1 min-w-0">
      <%# Examples grid %>
      <div class="p-4">
        <div class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4 gap-4 space-y-4">

          <%# — Login Card — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_header class: "text-center" do %>
                <%= ui.card_title "Sign in" %>
                <%= ui.card_subtitle "Enter your credentials to continue" %>
              <% end %>
              <%= ui.card_body class: "form flex flex-col gap-3" do %>
                <div class="form__group">
                  <label class="form__label">Email</label>
                  <input autocomplete="off" type="email" class="form__field" placeholder="name@example.com">
                </div>
                <div class="form__group">
                  <label class="form__label">Password</label>
                  <input autocomplete="off" type="password" class="form__field" placeholder="********">
                </div>
                <label class="flex items-center gap-2">
                  <input type="checkbox" class="form__checkbox">
                  <span class="form__label">Remember me</span>
                </label>
                <%= ui.btn "Sign in", variant: :default, class: "w-full" %>
                <p class="text-center text-sm text-muted-foreground">Don't have an account? <a href="#" class="text-primary font-medium">Sign up</a></p>
              <% end %>
            <% end %>
          </div>

          <%# — Stats Cards — %>
          <div class="break-inside-avoid">
            <div class="grid grid-cols-2 gap-3">
              <%= ui.card do %>
                <%= ui.card_body do %>
                  <p class="text-sm text-muted-foreground">Revenue</p>
                  <p class="text-2xl font-bold">$45,231</p>
                  <p class="text-xs text-emerald-600">+20.1%</p>
                <% end %>
              <% end %>
              <%= ui.card do %>
                <%= ui.card_body do %>
                  <p class="text-sm text-muted-foreground">Users</p>
                  <p class="text-2xl font-bold">2,350</p>
                  <p class="text-xs text-emerald-600">+180.1%</p>
                <% end %>
              <% end %>
              <%= ui.card do %>
                <%= ui.card_body do %>
                  <p class="text-sm text-muted-foreground">Orders</p>
                  <p class="text-2xl font-bold">12,234</p>
                  <p class="text-xs text-rose-600">-2.5%</p>
                <% end %>
              <% end %>
              <%= ui.card do %>
                <%= ui.card_body do %>
                  <p class="text-sm text-muted-foreground">Active</p>
                  <p class="text-2xl font-bold">573</p>
                  <p class="text-xs text-emerald-600">+4.3%</p>
                <% end %>
              <% end %>
            </div>
          </div>

          <%# — Buttons Showcase — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_header do %>
                <%= ui.card_title "Buttons" %>
              <% end %>
              <%= ui.card_body class: "flex flex-col gap-3" do %>
                <div class="flex flex-wrap items-center gap-2">
                  <%= ui.btn "Primary", variant: :default, size: :sm %>
                  <%= ui.btn "Secondary", variant: :secondary, size: :sm %>
                  <%= ui.btn "Outline", variant: :outline, size: :sm %>
                  <%= ui.btn "Ghost", variant: :ghost, size: :sm %>
                  <%= ui.btn "Danger", variant: :danger, size: :sm %>
                </div>
                <div class="flex flex-wrap items-center gap-2">
                  <%= ui.btn "Extra Small", variant: :default, size: :xs %>
                  <%= ui.btn "Small", variant: :default, size: :sm %>
                  <%= ui.btn "Medium", variant: :default, size: :md %>
                  <%= ui.btn "Large", variant: :default, size: :lg %>
                </div>
              <% end %>
            <% end %>
          </div>

          <%# — User Profile Card — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_body class: "flex items-center gap-4" do %>
                <%= ui.avatar size: 12 %>
                <div class="flex-1 min-w-0">
                  <p class="font-semibold truncate">Aleksei Solilin</p>
                  <p class="text-sm text-muted-foreground truncate">aleksei@jetrockets.com</p>
                </div>
                <%= ui.btn "Edit", variant: :outline, size: :sm %>
              <% end %>
            <% end %>
          </div>

          <%# — Notifications List — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_header do %>
                <%= ui.card_title "Notifications" %>
                <%= ui.card_subtitle "You have 3 unread messages." %>
              <% end %>
              <%= ui.card_body class: "flex flex-col divide-y divide-border -my-1" do %>
                <% [
                  { title: "New comment on PR #42", time: "2 min ago", unread: true },
                  { title: "Deploy succeeded", time: "1 hour ago", unread: true },
                  { title: "New team member joined", time: "3 hours ago", unread: true },
                  { title: "Weekly report ready", time: "Yesterday", unread: false },
                ].each do |n| %>
                  <div class="flex items-start gap-3 py-3">
                    <div class="mt-1.5 size-2 rounded-full shrink-0 <%= n[:unread] ? 'bg-primary' : 'bg-transparent' %>"></div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium truncate"><%= n[:title] %></p>
                      <p class="text-xs text-muted-foreground"><%= n[:time] %></p>
                    </div>
                  </div>
                <% end %>
              <% end %>
            <% end %>
          </div>

          <%# — Badges — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_header do %>
                <%= ui.card_title "Badges" %>
              <% end %>
              <%= ui.card_body class: "flex flex-wrap gap-2" do %>
                <%= ui.badge "Default", size: :md %>
                <%= ui.badge "Info", variant: :info, size: :md %>
                <%= ui.badge "Success", variant: :success, size: :md %>
                <%= ui.badge "Warning", variant: :warning, size: :md %>
                <%= ui.badge "Error", variant: :error, size: :md %>
                <%= ui.badge "Rounded", variant: :info, size: :md, rounded: true %>
              <% end %>
            <% end %>
          </div>

          <%# — Settings Form — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_header do %>
                <%= ui.card_title "Settings" %>
                <%= ui.card_subtitle "Manage your account preferences." %>
              <% end %>
              <%= ui.card_body class: "form flex flex-col gap-3" do %>
                <div class="form__group">
                  <label class="form__label">Display Name</label>
                  <input autocomplete="off" type="text" class="form__field" value="Aleksei Solilin">
                </div>
                <div class="form__group">
                  <label class="form__label">Language</label>
                  <select class="form__field">
                    <option>English</option>
                    <option>Russian</option>
                    <option>Spanish</option>
                  </select>
                </div>
                <div class="form__group">
                  <label class="form__label">Bio</label>
                  <textarea class="form__field" rows="2" placeholder="Tell us about yourself..."></textarea>
                </div>
              <% end %>
              <%= ui.card_footer class: "flex justify-end gap-2" do %>
                <%= ui.btn "Cancel", variant: :ghost, size: :sm %>
                <%= ui.btn "Save changes", variant: :default, size: :sm %>
              <% end %>
            <% end %>
          </div>

          <%# — Pricing Card — %>
          <div class="break-inside-avoid">
            <%= ui.card class: "border-primary" do %>
              <%= ui.card_header do %>
                <%= ui.badge "Popular", variant: :info, size: :sm, rounded: true %>
                <%= ui.card_title "Pro Plan" %>
                <%= ui.card_subtitle "Best for growing teams" %>
              <% end %>
              <%= ui.card_body do %>
                <div class="flex items-baseline gap-1 mb-4">
                  <span class="text-4xl font-bold">$29</span>
                  <span class="text-muted-foreground">/month</span>
                </div>
                <ul class="space-y-2 text-sm">
                  <% ["Unlimited projects", "Priority support", "Advanced analytics", "Custom integrations", "Team collaboration"].each do |feature| %>
                    <li class="flex items-center gap-2">
                      <%= ui.icon "check", size: 4, class: "text-primary" %>
                      <span><%= feature %></span>
                    </li>
                  <% end %>
                </ul>
              <% end %>
              <%= ui.card_footer do %>
                <%= ui.btn "Get started", variant: :default, class: "w-full" %>
              <% end %>
            <% end %>
          </div>

          <%# — Alerts — %>
          <div class="break-inside-avoid">
            <div class="flex flex-col gap-3">
              <%= ui.alert(title: "Heads up!", variant: :info) { "New version available. Update now for latest features." } %>
              <%= ui.alert(title: "Success", variant: :success) { "Your changes have been saved." } %>
              <%= ui.alert(title: "Warning", variant: :warning) { "Your trial ends in 3 days." } %>
              <%= ui.alert(title: "Error", variant: :error) { "Something went wrong. Please try again." } %>
            </div>
          </div>

          <%# — Team Members Table — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_header do %>
                <%= ui.card_title "Team" %>
              <% end %>
              <%= ui.table size: :sm do %>
                <%= ui.table_thead do %>
                  <%= ui.table_tr do %>
                    <%= ui.table_th "Name" %>
                    <%= ui.table_th "Role" %>
                    <%= ui.table_th "Status" %>
                  <% end %>
                <% end %>
                <%= ui.table_tbody do %>
                  <% [
                    { name: "Alice Chen", role: "Engineer", status: "Active", variant: :success },
                    { name: "Bob Smith", role: "Designer", status: "Active", variant: :success },
                    { name: "Carol Wu", role: "PM", status: "Away", variant: :warning },
                    { name: "Dave Kim", role: "Engineer", status: "Offline", variant: :error },
                  ].each do |member| %>
                    <%= ui.table_tr do %>
                      <%= ui.table_td class: "font-medium" do %><%= member[:name] %><% end %>
                      <%= ui.table_td class: "text-muted-foreground" do %><%= member[:role] %><% end %>
                      <%= ui.table_td do %><%= ui.badge member[:status], variant: member[:variant], size: :sm %><% end %>
                    <% end %>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>
          </div>

          <%# — Tabs + Content — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_header do %>
                <%= ui.tabs do %>
                  <%= ui.tabs_item "Overview", href: "#", active: true %>
                  <%= ui.tabs_item "Analytics", href: "#" %>
                  <%= ui.tabs_item "Reports", href: "#" %>
                <% end %>
              <% end %>
              <%= ui.card_body do %>
                <p class="text-sm text-muted-foreground">Your overview dashboard shows key metrics and recent activity across all projects.</p>
                <div class="mt-4 grid grid-cols-3 gap-3">
                  <div class="text-center">
                    <p class="text-2xl font-bold">128</p>
                    <p class="text-xs text-muted-foreground">Projects</p>
                  </div>
                  <div class="text-center">
                    <p class="text-2xl font-bold">1.4k</p>
                    <p class="text-xs text-muted-foreground">Commits</p>
                  </div>
                  <div class="text-center">
                    <p class="text-2xl font-bold">99.9%</p>
                    <p class="text-xs text-muted-foreground">Uptime</p>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>

          <%# — Dropdown — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_header do %>
                <%= ui.card_title "Dropdown" %>
              <% end %>
              <%= ui.card_body class: "flex gap-3" do %>
                <%= ui.dropdown do %>
                  <%= ui.dropdown_trigger do %>
                    <%= ui.btn variant: :outline, size: :sm do %>
                      Actions <%= ui.icon("chevron-down", class: "size-4") %>
                    <% end %>
                  <% end %>
                  <%= ui.dropdown_menu do %>
                    <%= ui.dropdown_link(url: "#") { "Edit" } %>
                    <%= ui.dropdown_link(url: "#") { "Duplicate" } %>
                    <%= ui.dropdown_divider %>
                    <%= ui.dropdown_link(url: "#") { "Delete" } %>
                  <% end %>
                <% end %>
                <%= ui.dropdown do %>
                  <%= ui.dropdown_trigger do %>
                    <%= ui.btn variant: :default, size: :sm do %>
                      Menu <%= ui.icon("chevron-down", class: "size-4") %>
                    <% end %>
                  <% end %>
                  <%= ui.dropdown_menu do %>
                    <%= ui.dropdown_link(url: "#") { "Profile" } %>
                    <%= ui.dropdown_link(url: "#") { "Settings" } %>
                    <%= ui.dropdown_divider %>
                    <%= ui.dropdown_link(url: "#") { "Sign out" } %>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>
          </div>

          <%# — Accordion / FAQ — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_header do %>
                <%= ui.card_title "FAQ" %>
              <% end %>
              <div class="divide-y divide-border">
                <%= ui.accordion name: "builder-faq", open: true do %>
                  <%= ui.accordion_summary(class: "px-4") { "Is it accessible?" } %>
                  <%= ui.accordion_body class: "px-4 pb-4 text-sm text-muted-foreground" do %>
                    Yes. It adheres to the WAI-ARIA design pattern.
                  <% end %>
                <% end %>
                <%= ui.accordion name: "builder-faq" do %>
                  <%= ui.accordion_summary(class: "px-4") { "Is it styled?" } %>
                  <%= ui.accordion_body class: "px-4 pb-4 text-sm text-muted-foreground" do %>
                    Yes. It comes with default styles that match your theme.
                  <% end %>
                <% end %>
                <%= ui.accordion name: "builder-faq" do %>
                  <%= ui.accordion_summary(class: "px-4") { "Is it animated?" } %>
                  <%= ui.accordion_body class: "px-4 pb-4 text-sm text-muted-foreground" do %>
                    Yes. It's animated by default with smooth transitions.
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>

          <%# — Tooltip Showcase — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_header do %>
                <%= ui.card_title "Tooltips" %>
              <% end %>
              <%= ui.card_body class: "flex flex-wrap gap-3" do %>
                <%= ui.tooltip title: "Top tooltip", placement: :top do %>
                  <%= ui.btn "Top", variant: :outline, size: :sm %>
                <% end %>
                <%= ui.tooltip title: "Right tooltip", placement: :right do %>
                  <%= ui.btn "Right", variant: :outline, size: :sm %>
                <% end %>
                <%= ui.tooltip title: "Bottom tooltip", placement: :bottom do %>
                  <%= ui.btn "Bottom", variant: :outline, size: :sm %>
                <% end %>
                <%= ui.tooltip title: "Left tooltip", placement: :left do %>
                  <%= ui.btn "Left", variant: :outline, size: :sm %>
                <% end %>
              <% end %>
            <% end %>
          </div>

          <%# — Sign Up Card — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_header class: "text-center" do %>
                <%= ui.card_title "Create account" %>
                <%= ui.card_subtitle "Start your 14-day free trial" %>
              <% end %>
              <%= ui.card_body class: "form flex flex-col gap-3" do %>
                <div class="grid grid-cols-2 gap-3">
                  <div class="form__group">
                    <label class="form__label">First name</label>
                    <input autocomplete="off" type="text" class="form__field" placeholder="John">
                  </div>
                  <div class="form__group">
                    <label class="form__label">Last name</label>
                    <input autocomplete="off" type="text" class="form__field" placeholder="Doe">
                  </div>
                </div>
                <div class="form__group">
                  <label class="form__label">Email</label>
                  <input autocomplete="off" type="email" class="form__field" placeholder="john@example.com">
                </div>
                <div class="form__group">
                  <label class="form__label">Password</label>
                  <input autocomplete="off" type="password" class="form__field" placeholder="Create a password">
                </div>
                <label class="flex items-start gap-2">
                  <input type="checkbox" class="form__checkbox mt-0.5">
                  <span class="form__label text-xs font-normal">I agree to the <a href="#" class="text-primary">Terms of Service</a> and <a href="#" class="text-primary">Privacy Policy</a></span>
                </label>
                <%= ui.btn "Create account", variant: :default, class: "w-full" %>
              <% end %>
            <% end %>
          </div>

          <%# — Avatars — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_header do %>
                <%= ui.card_title "Avatars" %>
              <% end %>
              <%= ui.card_body class: "flex flex-col gap-4" do %>
                <div class="flex items-center gap-3">
                  <%= ui.avatar size: 8 %>
                  <%= ui.avatar size: 10 %>
                  <%= ui.avatar size: 12 %>
                  <%= ui.avatar size: 14 %>
                </div>
                <div class="flex items-center gap-3">
                  <%= ui.avatar size: 10, variant: :rounded %>
                  <%= ui.avatar size: 10, variant: :square %>
                  <%= ui.avatar size: 10 %>
                </div>
              <% end %>
            <% end %>
          </div>

          <%# — Invoice / Payment Card — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_header do %>
                <%= ui.card_title "Recent Payments" %>
              <% end %>
              <%= ui.table size: :sm do %>
                <%= ui.table_thead do %>
                  <%= ui.table_tr do %>
                    <%= ui.table_th "Invoice" %>
                    <%= ui.table_th "Status" %>
                    <%= ui.table_th "Amount", class: "text-right" %>
                  <% end %>
                <% end %>
                <%= ui.table_tbody do %>
                  <% [
                    { id: "INV-001", status: "Paid", amount: "$250.00", variant: :success },
                    { id: "INV-002", status: "Pending", amount: "$150.00", variant: :warning },
                    { id: "INV-003", status: "Paid", amount: "$350.00", variant: :success },
                    { id: "INV-004", status: "Failed", amount: "$450.00", variant: :error },
                    { id: "INV-005", status: "Paid", amount: "$550.00", variant: :success },
                  ].each do |inv| %>
                    <%= ui.table_tr do %>
                      <%= ui.table_td class: "font-medium" do %><%= inv[:id] %><% end %>
                      <%= ui.table_td do %><%= ui.badge inv[:status], variant: inv[:variant], size: :sm %><% end %>
                      <%= ui.table_td class: "text-right" do %><%= inv[:amount] %><% end %>
                    <% end %>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>
          </div>

          <%# — Form Elements — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_header do %>
                <%= ui.card_title "Form Elements" %>
              <% end %>
              <%= ui.card_body class: "form flex flex-col gap-3" do %>
                <div class="form__group">
                  <label class="form__label">Text Input</label>
                  <input autocomplete="off" type="text" class="form__field" placeholder="Enter text...">
                </div>
                <div class="form__group">
                  <label class="form__label">Select</label>
                  <select class="form__field">
                    <option>Option 1</option>
                    <option>Option 2</option>
                    <option>Option 3</option>
                  </select>
                </div>
                <div class="flex items-center gap-6">
                  <label class="flex items-center gap-2">
                    <input type="checkbox" class="form__checkbox" checked>
                    <span class="text-sm">Checkbox</span>
                  </label>
                </div>
                <div class="flex items-center gap-6">
                  <label class="flex items-center gap-2">
                    <input type="radio" name="builder-radio" class="form__radio" checked>
                    <span class="text-sm">Radio 1</span>
                  </label>
                  <label class="flex items-center gap-2">
                    <input type="radio" name="builder-radio" class="form__radio">
                    <span class="text-sm">Radio 2</span>
                  </label>
                </div>
              <% end %>
            <% end %>
          </div>

          <%# — Empty State — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_body class: "py-10 text-center" do %>
                <div class="flex flex-col items-center gap-3">
                  <%= ui.icon "inbox", size: 10, class: "text-muted-foreground" %>
                  <div>
                    <p class="font-semibold">No results found</p>
                    <p class="text-sm text-muted-foreground mt-1">Try adjusting your search or filters.</p>
                  </div>
                  <%= ui.btn "Clear filters", variant: :outline, size: :sm %>
                </div>
              <% end %>
            <% end %>
          </div>

          <%# — Activity Feed — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_header do %>
                <%= ui.card_title "Activity" %>
              <% end %>
              <%= ui.card_body class: "flex flex-col gap-4" do %>
                <% [
                  { user: "Alice", action: "pushed to", target: "main", time: "2m ago" },
                  { user: "Bob", action: "opened PR", target: "#128", time: "15m ago" },
                  { user: "Carol", action: "commented on", target: "#125", time: "1h ago" },
                  { user: "Dave", action: "merged PR", target: "#124", time: "3h ago" },
                ].each do |item| %>
                  <div class="flex items-center gap-3">
                    <%= ui.avatar size: 7 %>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm"><strong><%= item[:user] %></strong> <span class="text-muted-foreground"><%= item[:action] %></span> <strong><%= item[:target] %></strong></p>
                    </div>
                    <span class="text-xs text-muted-foreground shrink-0"><%= item[:time] %></span>
                  </div>
                <% end %>
              <% end %>
            <% end %>
          </div>

          <%# — Feature Card — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_body class: "flex flex-col gap-4" do %>
                <div class="flex size-10 items-center justify-center rounded-lg bg-primary/10">
                  <%= ui.icon "bolt", size: 5, class: "text-primary" %>
                </div>
                <div>
                  <h3 class="font-semibold">Lightning Fast</h3>
                  <p class="text-sm text-muted-foreground mt-1">Optimized for speed with server-rendered components and minimal JavaScript overhead.</p>
                </div>
              <% end %>
            <% end %>
          </div>

          <%# — Testimonial — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_body class: "flex flex-col gap-4" do %>
                <div class="flex gap-1">
                  <% 5.times do %>
                    <%= ui.icon "star", size: 4, class: "text-amber-400 fill-amber-400" %>
                  <% end %>
                </div>
                <p class="text-sm italic text-muted-foreground">"This component library saved us weeks of development. Clean, accessible, and beautifully designed."</p>
                <div class="flex items-center gap-3">
                  <%= ui.avatar size: 8 %>
                  <div>
                    <p class="text-sm font-semibold">Sarah Johnson</p>
                    <p class="text-xs text-muted-foreground">CTO at TechCorp</p>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>

          <%# — Progress / Stepper — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_header do %>
                <%= ui.card_title "Project Progress" %>
              <% end %>
              <%= ui.card_body class: "flex flex-col gap-3" do %>
                <% [
                  { name: "Design", pct: 100 },
                  { name: "Frontend", pct: 72 },
                  { name: "Backend", pct: 45 },
                  { name: "Testing", pct: 10 },
                ].each do |item| %>
                  <div>
                    <div class="flex justify-between text-sm mb-1">
                      <span><%= item[:name] %></span>
                      <span class="text-muted-foreground"><%= item[:pct] %>%</span>
                    </div>
                    <div class="h-2 rounded-full bg-secondary">
                      <div class="h-2 rounded-full bg-primary" style="width: <%= item[:pct] %>%"></div>
                    </div>
                  </div>
                <% end %>
              <% end %>
            <% end %>
          </div>

          <%# — Calendar / Date Card — %>
          <div class="break-inside-avoid">
            <%= ui.card do %>
              <%= ui.card_header do %>
                <%= ui.card_title "Upcoming Events" %>
              <% end %>
              <%= ui.card_body class: "flex flex-col divide-y divide-border -my-1" do %>
                <% [
                  { date: "Apr 2", title: "Team standup", time: "9:00 AM" },
                  { date: "Apr 3", title: "Design review", time: "2:00 PM" },
                  { date: "Apr 5", title: "Sprint demo", time: "11:00 AM" },
                  { date: "Apr 7", title: "Retro", time: "4:00 PM" },
                ].each do |event| %>
                  <div class="flex items-center gap-4 py-3">
                    <div class="text-center shrink-0 w-10">
                      <p class="text-xs text-muted-foreground"><%= event[:date].split(" ").first %></p>
                      <p class="text-lg font-bold"><%= event[:date].split(" ").last %></p>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium"><%= event[:title] %></p>
                      <p class="text-xs text-muted-foreground"><%= event[:time] %></p>
                    </div>
                  </div>
                <% end %>
              <% end %>
            <% end %>
          </div>

          <%# — CTA Card — %>
          <div class="break-inside-avoid">
            <%= ui.card class: "bg-primary text-primary-foreground" do %>
              <%= ui.card_body class: "flex flex-col items-center text-center gap-4 py-8" do %>
                <h3 class="text-xl font-bold">Ready to get started?</h3>
                <p class="text-sm opacity-90">Join thousands of developers building beautiful interfaces.</p>
                <div class="flex gap-3">
                  <%= ui.btn "Get Started", variant: :secondary, size: :sm %>
                  <%= ui.btn "Learn More", variant: :outline, size: :sm, class: "border-primary-foreground/30 text-primary-foreground hover:bg-primary-foreground/10" %>
                </div>
              <% end %>
            <% end %>
          </div>

        </div>
      </div>
    </main>
  </div>
</div>
