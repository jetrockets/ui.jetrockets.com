<% set_meta_tags(
  title: "Card - Rails UI Components",
  description: "Card component for displaying grouped content.",
  keywords: "Rails, UI Components, Card"
) %>
<% breadcrumb :ui_card %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Card" %>
    <%= ui.header_subtitle "Card component for displaying grouped content." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/card", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("card") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("card") %>
  </section>

  <%= render_content_info("card") %>
  <%= render_props_table("card") %>
  <%= render_subcomponents_table("card") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("card") %>
  </section>
</article>
