<%
  set_meta_tags(
    title: "Colors - Rails UI Components",
    description: "Semantic color tokens and design system theme.",
    keywords: "Rails, UI Components, Colors, Design Tokens, Semantic Colors"
  )
%>
<% breadcrumb :ui_colors %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Colors" %>
    <%= ui.header_subtitle "Semantic color tokens that adapt to light and dark themes automatically." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "Theme Builder", url: builder_path, variant: :default %>
    <%= ui.btn "View brand.css", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/assets/stylesheets/brand.css", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%# How it works %>
  <section>
    <h2 class="h3 mb-4">How it works</h2>
    <div class="grid gap-4 lg:grid-cols-3">
      <% [
        { title: "brand.css", desc: "Define raw color variables with light and dark values", icon: "paint-brush" },
        { title: "theme.css", desc: "Maps variables to Tailwind utilities via @theme inline", icon: "swatch" },
        { title: "Templates", desc: "Use semantic classes like bg-primary, text-foreground", icon: "code-bracket" },
      ].each do |item| %>
        <%= ui.card do %>
          <%= ui.card_body class: "flex gap-4" do %>
            <div class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-primary/10">
              <%= ui.icon item[:icon], size: 5, class: "text-primary" %>
            </div>
            <div>
              <h3 class="text-foreground font-semibold"><%= item[:title] %></h3>
              <p class="text-muted-foreground mt-1 text-sm"><%= item[:desc] %></p>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <div class="mt-6">
      <pre><code>/* Use Tailwind utilities in templates */
bg-primary text-primary-foreground
bg-destructive-soft text-destructive-soft-foreground
border-border

/* Or CSS variables in custom styles */
background-color: var(--color-primary);
color: var(--color-foreground);</code></pre>
    </div>
  </section>

  <%# Layout Colors %>
  <section>
    <h2 class="h3 mb-4">Layout</h2>
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
      <% [
        ["Background", "--background", "--color-background"],
        ["Foreground", "--foreground", "--color-foreground"],
        ["Card", "--card", "--color-card"],
        ["Popover", "--popover", "--color-popover"],
        ["Muted", "--muted", "--color-muted"],
        ["Border", "--border", "--color-border"]
      ].each do |label, raw, token| %>
        <div class="flex flex-col">
          <div class="h-16 rounded-lg border border-border shadow-sm" style="background-color: var(<%= token %>)"></div>
          <div class="mt-2">
            <p class="text-sm font-medium"><%= label %></p>
            <p class="font-mono text-xs text-muted-foreground"><%= raw %></p>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <%# Primary & Secondary %>
  <section>
    <h2 class="h3 mb-4">Primary & Secondary</h2>
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
      <% [
        ["Primary", "--color-primary"],
        ["Primary Hover", "--color-primary-hover"],
        ["Primary FG", "--color-primary-foreground"],
        ["Secondary", "--color-secondary"],
        ["Secondary FG", "--color-secondary-foreground"],
        ["Accent", "--color-accent"]
      ].each do |label, token| %>
        <div class="flex flex-col">
          <div class="h-16 rounded-lg border border-border shadow-sm" style="background-color: var(<%= token %>)"></div>
          <div class="mt-2">
            <p class="text-sm font-medium"><%= label %></p>
            <p class="font-mono text-xs text-muted-foreground"><%= token.delete_prefix("--color-") %></p>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <%# Status Colors %>
  <section>
    <h2 class="h3 mb-2">Status Colors</h2>
    <p class="text-muted-foreground mb-6 text-sm">Soft, border and hover variants are auto-generated via <code class="bg-muted rounded px-1 py-0.5 text-xs">relative-color-syntax</code>.</p>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <% %w[destructive success warning info].each do |status| %>
        <%= ui.card do %>
          <%= ui.card_body do %>
            <h4 class="mb-3 font-semibold capitalize"><%= status %></h4>
            <div class="grid grid-cols-2 gap-2">
              <div class="flex flex-col">
                <div class="h-12 rounded-lg bg-<%= status %>"></div>
                <p class="mt-1 font-mono text-xs text-muted-foreground">base</p>
              </div>
              <div class="flex flex-col">
                <div class="h-12 rounded-lg border bg-<%= status %>-soft border-<%= status %>-border"></div>
                <p class="mt-1 font-mono text-xs text-muted-foreground">soft</p>
              </div>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </section>

  <%# Brand File %>
  <section>
    <h2 class="h3 mb-4">Brand File</h2>
    <p class="text-muted-foreground mb-4 text-sm">Create your own <code class="bg-muted rounded px-1 py-0.5 text-xs">brand.css</code> to customize the theme. Only raw variables — no computed values needed.</p>
    <%= ui.card do %>
      <%= ui.card_body do %>
        <pre class="text-sm"><code>:root {
  --background: oklch(1 0 0);
  --foreground: oklch(0.141 0.005 285.823);
  --overlay: oklch(0.21 0.006 264 / 0.5);
  --card: oklch(1 0 0);
  --card-foreground: var(--foreground);
  --popover: oklch(1 0 0);
  --popover-foreground: var(--foreground);
  --primary: oklch(0.205 0 0);
  --primary-foreground: oklch(0.985 0 0);
  --secondary: oklch(0.97 0 0);
  --secondary-foreground: oklch(0.205 0 0);
  --accent: oklch(0.97 0 0);
  --accent-foreground: oklch(0.205 0 0);
  --muted: oklch(0.97 0 0);
  --muted-foreground: oklch(0.556 0 0);
  --border: oklch(0.922 0 0);
  --input: oklch(0.922 0 0);
  --input-focus: oklch(from var(--primary) l c h / 40%);
  --input-ring: oklch(from var(--primary) l c h / 10%);
  --destructive: oklch(0.577 0.245 27);
  --success: oklch(0.6 0.19 145);
  --warning: oklch(0.8 0.16 85);
  --info: oklch(0.6 0.19 240);
}

.dark {
  --background: oklch(0.145 0 0);
  --foreground: oklch(0.985 0 0);
  /* ... override all variables for dark mode */
}</code></pre>
      <% end %>
    <% end %>
  </section>
</article>
