<%
  set_meta_tags(
    title: "Group - Rails UI Components",
    description: "Group component for grouping related elements together.",
    keywords: "Rails, UI Components, Group"
  )
%>
<% breadcrumb :ui_group %>

<article>
  <%= ui.header do %>
    <%= ui.header_heading do %>
      <%= ui.header_title "Group" %>
      <%= ui.header_subtitle "Group component for grouping related elements together." %>
    <% end %>
    <%= ui.header_actions do %>
      <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/group", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
    <% end %>
  <% end %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Example</h2>
    <%= ui.tabs do %>
      <%= ui.tabs_item "Preview", href: ui_group_path, active: !params[:code] %>
      <%= ui.tabs_item "Code", href: ui_group_path(code: true), active: params[:code] %>
    <% end %>

    <div class="flex flex-col gap-2">
      <% unless params[:code] %>
        <%= render "ui/examples/group" %>
      <% else %>
        <%= render_code_example("ui/examples/_group") %>
      <% end %>
    </div>
  </section>
</article>
