<%
  set_meta_tags(
    title: "Empty - Rails UI Components",
    description: "Empty state component for displaying placeholder content when no data is available.",
    keywords: "Rails, Empty State, UI Components, Placeholder, No Data"
  )
%>
<% breadcrumb :ui_empty %>

<article>
  <%= ui.header do %>
    <%= ui.header_heading do %>
      <%= ui.header_title "Empty" %>
      <%= ui.header_subtitle "Display empty states when no data is available or to guide users to take action." %>
    <% end %>
    <%= ui.header_actions do %>
      <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/empty", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
    <% end %>
  <% end %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Example</h2>
    <%= ui.tabs do %>
      <%= ui.tabs_item "Preview", href: ui_empty_path, active: !params[:code] %>
      <%= ui.tabs_item "Code", href: ui_empty_path(code: true), active: params[:code] %>
    <% end %>

    <div class="flex flex-col gap-6">
      <% unless params[:code] %>
        <%= render "ui/examples/empty" %>
      <% else %>
        <%= render_code_example("ui/examples/_empty") %>
      <% end %>
    </div>
  </section>
</article>
