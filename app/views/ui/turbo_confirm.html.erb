<%
  set_meta_tags(
    title: "Turbo Confirm - Rails UI Components",
    description: "Turbo Confirm component for confirmation modals.",
    keywords: "Rails, UI Components, Turbo Confirm"
  )
%>
<% breadcrumb :ui_turbo_confirm %>

<article>
  <%= ui.header do %>
    <%= ui.header_heading do %>
      <%= ui.header_title "Turbo Confirm" %>
      <%= ui.header_subtitle "Turbo Confirm component for confirmation modals." %>
    <% end %>
    <%= ui.header_actions do %>
      <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/turbo_confirm", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
    <% end %>
  <% end %>

  <section>
    <div class="flex flex-col gap-4 mb-12">
      <%= ui.alert variant: :warning do %>
        <%= ui.alert__title "To use the Turbo Confirm component, you need to set a custom confirm method using the following JavaScript code" %>
      <% end %>
      <pre><code>Turbo.setConfirmMethod((message) => {
  const dialog = document.getElementById('turbo-confirm')
  dialog.querySelector('p').textContent = message
  dialog.showModal()

  return new Promise((resolve) => {
    dialog.addEventListener('close', () => {
      resolve(dialog.returnValue === 'confirm')
    }, { once: true })

    dialog.addEventListener('click', (event) => {
      if (event.target.nodeName === 'DIALOG') {
        dialog.returnValue = 'cancel'
        dialog.close()
      }
    })
  })
})

&lt;!-- And somewhere in your layout --&gt;
&lt;%= ui.turbo_confirm %&gt;
</code></pre>
    </div>

    <div class="flex flex-col gap-4">
      <h2 class="h3">Example</h2>
      <%= ui.tabs do %>
        <%= ui.tabs_item "Preview", href: ui_turbo_confirm_path, active: !params[:code] %>
        <%= ui.tabs_item "Code", href: ui_turbo_confirm_path(code: true), active: params[:code] %>
      <% end %>

      <div class="flex flex-col gap-4 mb-12">
        <% unless params[:code] %>
          <%= render "ui/examples/turbo_confirm" %>
        <% else %>
          <%= render_code_example("ui/examples/_turbo_confirm") %>
        <% end %>
      </div>
    </div>
  </section>
</article>
