<% set_meta_tags(
  title: "Timeline - Rails UI Components",
  description: "Timeline component for displaying events and activity.",
  keywords: "Rails, UI Components, Timeline, Activity, Events"
) %>
<% breadcrumb :ui_timeline %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Timeline" %>
    <%= ui.header_subtitle "Vertical timeline for events and activity feed." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/timeline", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("timeline") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("timeline") %>
  </section>

  <%= render_content_info("timeline") %>
  <%= render_props_table("timeline") %>
  <%= render_subcomponents_table("timeline") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("timeline") %>
  </section>
</article>
