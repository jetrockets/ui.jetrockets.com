<%
  set_meta_tags(
    title: "Radio Button - Rails UI Components",
    description: "Radio button component with enhanced styling and accessibility features.",
    keywords: "Rails, UI Components, Radio Button, Form"
  )
%>
<% breadcrumb :ui_form_builders_radio_button %>

<article>
  <%= ui.header do %>
    <%= ui.header_heading do %>
      <%= ui.header_title do %>Rails <code class="px-1 text-3xl bg-yellow-100">radio_button</code> examples<% end %>
      <%= ui.header_subtitle "Enhanced radio button field with consistent styling, hint support, and improved accessibility for single-choice selection." %>
    <% end %>
    <%= ui.header_actions do %>
      <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/lib/form_builders/fields/radio_button.rb", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
    <% end %>
  <% end %>

  <section class="mb-12">
    <%= ui.card do %>
      <%= ui.card_header align: :left do %>
        <%= ui.card_title do %>Basic Radio Buttons<% end %>
      <% end %>

      <%= ui.card_body do %>
        <%= form_with url: root_path do |f| %>
          <%= f.group class: "form__radio_collection" do %>
            <%= f.radio_button :plan, "basic" %>
            <%= f.radio_button :plan, "pro", checked: true %>
            <%= f.radio_button :plan, "enterprise" %>
          <% end %>
        <% end %>
      <% end %>

      <%= ui.card_footer do %>
        <pre class="w-full"><code>&lt;%= f.group class: "form__radio_collection" do %&gt;
  &lt;%= f.radio_button :plan, "basic" %&gt;
  &lt;%= f.radio_button :plan, "pro", checked: true %&gt;
  &lt;%= f.radio_button :plan, "enterprise" %&gt;
&lt;% end %&gt;</code></pre>
      <% end %>
    <% end %>
  </section>

  <section class="my-12">
    <%= ui.card do %>
      <%= ui.card_header align: :left do %>
        <%= ui.card_title do %>Radio Button Collection<% end %>
      <% end %>

      <%= ui.card_body do %>
        <%= form_with url: root_path do |f| %>
          <%= f.radio_buttons_collection(:country_id, ISO3166::Country.find_all_countries_by_subregion("Northern America"), :alpha2, :common_name) %>
        <% end %>
      <% end %>

      <%= ui.card_footer do %>
        <pre class="w-full"><code>&lt;%= f.radio_buttons_collection(:country_id, ISO3166::Country.find_all_countries_by_subregion("Northern America"), :alpha2, :common_name) %&gt;</code></pre>
      <% end %>
    <% end %>
  </section>

  <section class="my-12">
    <%= ui.card do %>
      <%= ui.card_header align: :left do %>
        <%= ui.card_title do %>Label customization<% end %>
      <% end %>

      <%= ui.card_body do %>
        <%= form_with url: root_path do |f| %>
          <%= f.group class: "form__radio_collection" do %>
            <%= f.radio_button :custom_label, "custom", label: "Custom Label Text" %>
            <%= f.radio_button :custom_label, "with_link", label: "I agree to the #{link_to 'terms and conditions', '#', class: 'link'}".html_safe %>
            <%= f.radio_button :custom_label, "default" %>
          <% end %>
        <% end %>
      <% end %>

      <%= ui.card_footer do %>
        <pre class="w-full"><code>&lt;%= f.radio_button :custom_label, "custom", label: "Custom Label Text" %&gt;
&lt;%= f.radio_button :custom_label, "with_link", label: "I agree to the #{link_to 'terms and conditions', '#', class: 'link'}".html_safe %&gt;
&lt;%= f.radio_button :custom_label, "default" %&gt;</code></pre>
      <% end %>
    <% end %>
  </section>

  <section class="my-12">
    <%= ui.card do %>
      <%= ui.card_header align: :left do %>
        <%= ui.card_title do %>Hint messages<% end %>
      <% end %>

      <%= ui.card_body do %>
        <%= form_with url: root_path do |f| %>
          <%= f.group class: "form__radio_collection" do %>
            <%= f.radio_button :receive_emails, "yes", hint: "I agree to receive marketing emails" %>
            <%= f.radio_button :receive_emails, "no", hint: "I do not agree to receive marketing emails" %>
          <% end %>
        <% end %>
      <% end %>

      <%= ui.card_footer do %>
        <pre class="w-full"><code>&lt;%= f.radio_button :receive_emails, "yes", hint: "I agree to receive marketing emails" %&gt;&lt;%= f.radio_button :receive_emails, "no", hint: "I do not agree to receive marketing emails" %&gt;</code></pre>
      <% end %>
    <% end %>
  </section>

  <section class="my-12">
    <%= ui.card do %>
      <%= ui.card_header align: :left do %>
        <%= ui.card_title do %>Disabled State<% end %>
      <% end %>

      <%= ui.card_body do %>
        <%= form_with url: root_path do |f| %>
          <%= f.group class: "form__radio_collection" do %>
            <%= f.radio_button :disabled_group, "Option 1", disabled: true %>
            <%= f.radio_button :disabled_group_2, "Option 2", checked: true, disabled: true %>
          <% end %>
        <% end %>
      <% end %>

      <%= ui.card_footer do %>
        <pre class="w-full"><code>&lt;%= f.radio_button :disabled_group, "Option 1", disabled: true %&gt;&lt;% end %&gt;
&lt;%= f.radio_button :disabled_group_2, "Option 2", checked: true, disabled: true %&gt;&lt;% end %&gt;
        </code></pre>
      <% end %>
    <% end %>
  </section>

  <section class="my-12">
    <%= ui.card do %>
      <%= ui.card_header align: :left do %>
        <%= ui.card_title do %>Validation<% end %>
      <% end %>

      <%= ui.card_body do %>
        <% user = User.new %>
        <% user.errors.add(:validation, "is required") %>
        <%= form_with model: user, url: root_path do |f| %>
          <%= f.group class: "form__radio_collection" do %>
            <%= f.radio_button :validation, "standard" %>
            <%= f.radio_button :validation, "custom", error: "Custom error" %>
          <% end %>
        <% end %>
      <% end %>

      <%= ui.card_footer do %>
        <pre class="w-full"><code>&lt;!-- Active Record Validations works automatically --&gt;
&lt;%= f.radio_button :validation, "standard" %&gt;

&lt;!-- You are able to add custom error messages --&gt;
&lt;%= f.radio_button :validation, "custom", error: "Custom error" %&gt;</code></pre>
      <% end %>
    <% end %>
  </section>
</article>
