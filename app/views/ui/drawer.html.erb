<%
  set_meta_tags(
    title: "Drawer - Rails UI Components",
    description: "Drawer component for sliding panel overlays.",
    keywords: "Rails, UI Components, Drawer"
  )
%>
<% breadcrumb :ui_drawer %>

<article>
  <%= ui.header do %>
    <%= ui.header_heading do %>
      <%= ui.header_title "Drawer" %>
      <%= ui.header_subtitle "Drawer component for sliding panel overlays." %>
    <% end %>
    <%= ui.header_actions do %>
      <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/drawer", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
    <% end %>
  <% end %>

  <section>
    <div class="flex flex-col gap-4 mb-12">
      <%= ui.alert variant: :warning, class: "gap-2" do %>
        <%= ui.alert__title "To use async Drawer component, you need to have a <turbo-frame id='drawer'> in your layout" %>
        <pre class="w-full"><code>&lt;%= turbo_frame_tag :drawer %&gt;</code></pre>
        <p class="font-semibold">And wrap response content with the drawer component:</p>
        <pre class="w-full"><code>&lt;%= ui.drawer(title: "Title HERE") do %&gt;
  ...
&lt;% end %&gt;</code></pre>
      <% end %>
    </div>

    <section class="flex flex-col gap-4">
      <h2 class="h3">Example</h2>
      <%= ui.tabs do %>
        <%= ui.tabs_item "Preview", href: ui_drawer_path, active: !params[:code] %>
        <%= ui.tabs_item "Code", href: ui_drawer_path(code: true), active: params[:code] %>
      <% end %>

      <div>
        <% unless params[:code] %>
          <%= render "ui/examples/drawer" %>
        <% else %>
          <%= render_code_example("ui/examples/_drawer") %>
        <% end %>
      </div>
    </section>
  </section>
</article>
