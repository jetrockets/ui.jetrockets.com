<% set_meta_tags(
  title: "TextArea - Rails UI Components",
  description: "Textarea for multi-line text input with auto-grow functionality and hint support.",
  keywords: "Rails, UI Components, Form Builder, TextArea"
) %>
<% breadcrumb :ui_form_builders_text_area %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "TextArea" %>
    <%= ui.header_subtitle "Textarea for multi-line text input with auto-grow functionality and hint support." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/lib/form_builders/core_form_builder.rb", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("text_area") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("text_area") %>
  </section>

  <%= render_props_table("text_area") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("text_area") %>
  </section>
</article>
