<% set_meta_tags(
  title: "Select - Rails UI Components",
  description: "Enhanced select dropdown field with consistent styling and accessibility features.",
  keywords: "Rails, UI Components, Form Builder, Select"
) %>
<% breadcrumb :ui_form_builders_select %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Select" %>
    <%= ui.header_subtitle "Enhanced select dropdown field with consistent styling and accessibility features." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/lib/form_builders/fields/select.rb", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("select") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("select") %>
  </section>

  <%= render_props_table("select") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("select") %>
  </section>
</article>
