<% set_meta_tags(
  title: "Alert - Rails UI Components",
  description: "Alert component for displaying status messages and notifications.",
  keywords: "Rails, Alert, UI Components, Notifications, Status"
) %>
<% breadcrumb :ui_alert %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Alert" %>
    <%= ui.header_subtitle "Display important messages and status notifications to users." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/alert", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("alert") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("alert") %>
  </section>

  <%= render_props_table("alert") %>
  <%= render_subcomponents_table("alert") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("alert") %>
  </section>
</article>
