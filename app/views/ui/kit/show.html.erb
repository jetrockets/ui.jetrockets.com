<% set_meta_tags(
  title: "#{@category[:title]} - UI Kit",
  description: @category[:description],
  keywords: "Rails, UI Kit, #{@category[:title]}"
) %>
<% breadcrumb :ui_kit_category, @category[:title] %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title @category[:title] %>
    <%= ui.header_subtitle @category[:description] %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.badge "#{@variants.size} variants", variant: :info %>
  <% end %>
<% end %>

<article class="flex flex-col gap-16">
  <% @variants.each do |variant| %>
    <%= render_kit_block(variant, @category_key) %>
  <% end %>

  <% if @variants.empty? %>
    <%= ui.empty do %>
      <%= ui.empty_icon "cube" %>
      <%= ui.empty_title "Coming soon" %>
      <%= ui.empty_description "Blocks for this category are being designed." %>
    <% end %>
  <% end %>
</article>
