<% set_meta_tags(
  title: "Checkbox - Rails UI Components",
  description: "Enhanced checkbox field with consistent styling, hint support, and improved accessibility.",
  keywords: "Rails, UI Components, Form Builder, Checkbox"
) %>
<% breadcrumb :ui_form_builders_checkbox %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Checkbox" %>
    <%= ui.header_subtitle "Enhanced checkbox field with consistent styling, hint support, and improved accessibility." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/lib/form_builders/fields/check_box.rb", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("checkbox") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("checkbox") %>
  </section>

  <%= render_props_table("checkbox") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("checkbox") %>
  </section>
</article>
