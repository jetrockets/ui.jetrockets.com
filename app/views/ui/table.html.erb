<%
  set_meta_tags(
    title: "Table - Rails UI Components",
    description: "Table component for displaying tabular data.",
    keywords: "Rails, UI Components, Table"
  )
%>
<% breadcrumb :ui_table %>

<article>
  <%= ui.header do %>
    <%= ui.header_heading do %>
      <%= ui.header_title "Table" %>
      <%= ui.header_subtitle "Table component for displaying tabular data." %>
    <% end %>
    <%= ui.header_actions do %>
      <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/table", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
    <% end %>
  <% end %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Example</h2>
    <%= ui.tabs do %>
      <%= ui.tabs_item "Preview", href: ui_table_path, active: !params[:code] %>
      <%= ui.tabs_item "Code", href: ui_table_path(code: true), active: params[:code] %>
    <% end %>

    <div class="flex flex-col gap-2">
      <% unless params[:code] %>
        <div class="flex flex-col gap-8">
          <%= render "ui/examples/table" %>
        </div>
      <% else %>
        <%= render_code_example("ui/examples/_table") %>
      <% end %>
    </div>
  </section>
</article>
