<% set_meta_tags(
  title: "Sidebar - Rails UI Components",
  description: "Sidebar component for navigation menus.",
  keywords: "Rails, UI Components, Sidebar, Navigation"
) %>
<% breadcrumb :ui_sidebar %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Sidebar" %>
    <%= ui.header_subtitle "Navigation sidebar with sections, titles, and links." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/sidebar", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("sidebar") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("sidebar") %>
  </section>

  <%= render_content_info("sidebar") %>
  <%= render_props_table("sidebar") %>
  <%= render_subcomponents_table("sidebar") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("sidebar") %>
  </section>
</article>
