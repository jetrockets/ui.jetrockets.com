<% set_meta_tags(
  title: "Choices - Rails UI Components",
  description: "Enhanced select field with search functionality, multiple selection, and custom options using Choices.js.",
  keywords: "Rails, UI Components, Form Builder, Choices"
) %>
<% breadcrumb :ui_form_builders_choices %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Choices" %>
    <%= ui.header_subtitle do %>
      Enhanced select field with search functionality, multiple selection support, and custom options using
      <%= link_to "Choices.js", "https://github.com/Choices-js/Choices", class: "link", target: "_blank", rel: "noopener noreferrer" %>
      library.
    <% end %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/lib/form_builders/fields/choices.rb", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("choices") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("choices") %>
  </section>

  <%= render_props_table("choices") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("choices") %>
  </section>
</article>
