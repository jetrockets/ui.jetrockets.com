<%
  set_meta_tags(
    title: "Good to Know - Rails UI Components",
    description: "Architectural decisions, best practices, and important considerations for Rails UI components.",
    keywords: "Rails, UI, Components, Architecture, Best Practices, ViewComponent"
  )
%>
<% breadcrumb :ui_good_to_know %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Good to Know" %>
    <%= ui.header_subtitle "Architecture, patterns, and best practices for working with the component library." %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= ui.alert variant: :default, class: "lg:p-8 p-6"  do %>
    <%= ui.alert_icon "light-bulb", size: 8 %>
    <%= ui.alert_title "Copy, Don't Install", class: "text-foreground text-lg font-bold" %>
    <%= ui.alert_description class: "text-muted-foreground mt-2 leading-relaxed" do %>
      This is a <strong>template library</strong>, not a gem. Copy components to your project and customize them freely.
      You own the code — no version conflicts, no breaking upgrades, full control over styling and behavior.
    <% end %>
  <% end %>

  <%# Design Patterns %>
  <section>
    <h2 class="h2 mb-6">Component Design Patterns</h2>

    <div class="grid gap-6 lg:grid-cols-2">
      <%# Consistent API %>
      <%= ui.card do %>
        <%= ui.card_header do %>
          <%= ui.card_title do %>
            <%= ui.icon "code-bracket", size: 5, class: "text-primary" %>
            Consistent API
          <% end %>
          <%= ui.card_subtitle "All components follow similar initialization patterns" %>
        <% end %>
        <%= ui.card_body do %>
          <pre class="text-sm"><code>def initialize(variant: nil, size: :md, **options)
  @variant = variant   # Visual style
  @size = size         # Size modifier
  @options = options   # HTML attributes
end</code></pre>
        <% end %>
      <% end %>

      <%# Composition %>
      <%= ui.card do %>
        <%= ui.card_header do %>
          <%= ui.card_title do %>
            <%= ui.icon "puzzle-piece", size: 5, class: "text-primary" %>
            Composable
          <% end %>
          <%= ui.card_subtitle "Complex components use subcomponent composition" %>
        <% end %>
        <%= ui.card_body do %>
          <pre class="text-sm"><code>&lt;%= ui.card do %&gt;
  &lt;%= ui.card_header do %&gt;
    &lt;%= ui.card_title "Title" %&gt;
  &lt;% end %&gt;
  &lt;%= ui.card_body do %&gt;Content&lt;% end %&gt;
  &lt;%= ui.card_footer do %&gt;Footer&lt;% end %&gt;
&lt;% end %&gt;</code></pre>
        <% end %>
      <% end %>
    </div>
  </section>

  <%# CSS Strategy %>
  <section>
    <h2 class="h2 mb-6">CSS Strategy</h2>
    <div class="grid gap-4 sm:grid-cols-3">
      <% [
        { title: "Base Classes", desc: "Core component styling using TailwindCSS utilities", code: "@apply px-4 py-2 rounded-md font-medium" },
        { title: "Modifier Classes", desc: "BEM-like naming for variants and states", code: ".btn-default, .btn-lg, .btn-outline" },
        { title: "Dynamic Classes", desc: "Rails' class_names helper for conditionals", code: "class_names(\"btn\", \"btn-\#{variant}\")" },
      ].each do |item| %>
        <%= ui.card do %>
          <%= ui.card_body class: "flex flex-col gap-3" do %>
            <h3 class="text-foreground font-semibold"><%= item[:title] %></h3>
            <p class="text-muted-foreground text-sm"><%= item[:desc] %></p>
            <pre class="text-xs"><code><%= item[:code] %></code></pre>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </section>

  <%# HTML or ViewComponent %>
  <section>
    <h2 class="h2 mb-4">ViewComponent or plain HTML?</h2>
    <p class="text-muted-foreground mb-4">Both work — use whichever fits the context:</p>
    <div class="grid gap-4 lg:grid-cols-2">
      <%= ui.card do %>
        <%= ui.card_header do %>
          <%= ui.card_title "Via ui helper" %>
        <% end %>
        <%= ui.card_body do %>
          <pre class="text-sm"><code>&lt;%= ui.btn "Save", variant: :default, size: :lg %&gt;</code></pre>
        <% end %>
      <% end %>
      <%= ui.card do %>
        <%= ui.card_header do %>
          <%= ui.card_title "Via plain HTML" %>
        <% end %>
        <%= ui.card_body do %>
          <pre class="text-sm"><code>&lt;button class="btn btn-default btn-lg"&gt;Save&lt;/button&gt;</code></pre>
        <% end %>
      <% end %>
    </div>
  </section>

  <%# Styling Guidelines %>
  <section>
    <h2 class="h2 mb-6">Styling Guidelines</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      <%= ui.card do %>
        <%= ui.card_header do %>
          <%= ui.card_title do %>
            <%= ui.icon "check-circle", size: 5, class: "text-success" %>
            Do
          <% end %>
        <% end %>
        <%= ui.card_body do %>
          <ul class="flex flex-col gap-2">
            <% [
              "Use @apply for component base styles",
              "Use semantic color tokens (bg-primary, text-foreground)",
              "Use CSS custom properties for themeable values",
              "Design mobile-first with responsive prefixes",
              "Keep utility chains short in templates"
            ].each do |item| %>
              <li class="flex items-start gap-2 text-sm">
                <%= ui.icon "check", size: 4, class: "mt-0.5 text-success shrink-0" %>
                <span class="text-muted-foreground"><%= item %></span>
              </li>
            <% end %>
          </ul>
        <% end %>
      <% end %>

      <%= ui.card do %>
        <%= ui.card_header do %>
          <%= ui.card_title do %>
            <%= ui.icon "x-circle", size: 5, class: "text-destructive" %>
            Avoid
          <% end %>
        <% end %>
        <%= ui.card_body do %>
          <ul class="flex flex-col gap-2">
            <% [
              "Hardcoded color values (text-blue-600)",
              "Long utility chains in ERB templates",
              "Inline styles for themeable properties",
              "Overriding component internals with !important",
              "Skipping responsive breakpoints"
            ].each do |item| %>
              <li class="flex items-start gap-2 text-sm">
                <%= ui.icon "x-mark", size: 4, class: "mt-0.5 text-destructive shrink-0" %>
                <span class="text-muted-foreground"><%= item %></span>
              </li>
            <% end %>
          </ul>
        <% end %>
      <% end %>
    </div>
  </section>

  <%# Accessibility %>
  <section>
    <h2 class="h2 mb-6">Accessibility</h2>
    <div class="grid gap-4 lg:grid-cols-2">
      <%= ui.card do %>
        <%= ui.card_header do %>
          <%= ui.card_title do %>
            <%= ui.icon "shield-check", size: 5, class: "text-primary" %>
            Built-in
          <% end %>
        <% end %>
        <%= ui.card_body do %>
          <ul class="flex flex-col gap-2">
            <% ["Semantic HTML elements", "ARIA attributes where needed", "Keyboard navigation support", "Focus management for modals/dropdowns", "Screen reader friendly content"].each do |item| %>
              <li class="flex items-center gap-2 text-sm text-muted-foreground">
                <%= ui.icon "check-circle", size: 4, class: "text-primary" %>
                <%= item %>
              </li>
            <% end %>
          </ul>
        <% end %>
      <% end %>

      <%= ui.card do %>
        <%= ui.card_header do %>
          <%= ui.card_title do %>
            <%= ui.icon "hand-raised", size: 5, class: "text-primary" %>
            Your Responsibilities
          <% end %>
        <% end %>
        <%= ui.card_body do %>
          <ul class="flex flex-col gap-2">
            <% ["Provide meaningful alt text for images", "Ensure sufficient color contrast", "Test with screen readers", "Add ARIA labels for dynamic content", "Follow WCAG 2.1 guidelines"].each do |item| %>
              <li class="flex items-center gap-2 text-sm text-muted-foreground">
                <%= ui.icon "arrow-right", size: 4, class: "text-muted-foreground" %>
                <%= item %>
              </li>
            <% end %>
          </ul>
        <% end %>
      <% end %>
    </div>
  </section>

  <%# Customization %>
  <section>
    <h2 class="h2 mb-4">Making it yours</h2>
    <%= ui.alert variant: :default, class: "lg:p-8 p-6" do %>
      <%= ui.alert_title "This is your codebase once you copy the components.", class: "text-foreground text-lg font-bold" %>
      <%= ui.alert_description class: "col-span-2 text-muted-foreground mt-2 leading-relaxed" do %>
        Modify styling to match your brand, add new variants and sizes, extend functionality, remove unused components, or combine them into new ones.
        <div class="mt-3">
          <%= ui.btn url: ui_colors_path, variant: :outline, size: :sm do %>
            Customize theme colors
            <%= ui.icon "arrow-right", size: 4 %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </section>
</article>
