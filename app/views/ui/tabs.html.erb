<%
  set_meta_tags(
    title: "Tabs - Rails UI Components",
    description: "Tabs component for organizing content into sections.",
    keywords: "Rails, UI Components, Tabs"
  )
%>
<% breadcrumb :ui_tabs %>

<article>
  <%= ui.header do %>
    <%= ui.header_heading do %>
      <%= ui.header_title "Tabs" %>
      <%= ui.header_subtitle "Tabs component for organizing content into sections." %>
    <% end %>
    <%= ui.header_actions do %>
      <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/tabs", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
    <% end %>
  <% end %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Example</h2>
    <%= ui.tabs do %>
      <%= ui.tabs_item "Preview", href: ui_tabs_path, active: !params[:code] %>
      <%= ui.tabs_item "Code", href: ui_tabs_path(code: true), active: params[:code] %>
    <% end %>

    <div class="flex flex-col gap-2">
      <% unless params[:code] %>
        <%= render "ui/examples/tabs" %>
      <% else %>
        <%= render_code_example("ui/examples/_tabs") %>
      <% end %>
    </div>
  </section>
</article>
