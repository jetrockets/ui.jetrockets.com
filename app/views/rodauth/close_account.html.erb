<% set_meta_tags(title: "Are you sure?") %>

<%= ui.modal(title: "Are you sure?", size: :lg) do %>
  <%= ui.modal_body do %>
    <%= ui.alert variant: :info, class: "mb-4" do |alert| %>
      <strong>Deleting an account</strong> is a permanent action that cannot be undone.
    <% end %>

    <%= form_with url: rodauth.close_account_path, method: :post do |form| %>
      <% if rodauth.close_account_requires_password? %>
        <%= form.password_field rodauth.password_param, value: "", autocomplete: rodauth.password_field_autocomplete_value, required: true, error: rodauth.field_error(rodauth.password_param) %>
      <% end %>

      <div class="form__actions">
        <%= form.submit rodauth.close_account_button, block: true, variant: :danger %>
      </div>
    <% end %>
  <% end %>
<% end %>
