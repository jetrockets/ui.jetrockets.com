<%
  set_meta_tags(
    title: "Icon - Rails UI Components",
    description: "Icon component for SVG icons integration.",
    keywords: "Rails, UI Components, Icon"
  )
%>
<% breadcrumb :ui_icon %>

<article>
  <%= ui.header do %>
    <%= ui.header_heading do %>
      <%= ui.header_title "Icon" %>
      <%= ui.header_subtitle "Icon component for SVG icons integration." %>
    <% end %>
    <%= ui.header_actions do %>
      <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/icon", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
    <% end %>
  <% end %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Example</h2>
    <%= ui.tabs do %>
      <%= ui.tabs_item "Preview", href: ui_icon_path, active: !params[:code] %>
      <%= ui.tabs_item "Code", href: ui_icon_path(code: true), active: params[:code] %>
    <% end %>

    <div class="flex flex-col gap-2">
      <% unless params[:code] %>
        <%= render "ui/examples/icon" %>
      <% else %>
        <%= render_code_example("ui/examples/_icon") %>
      <% end %>
    </div>
  </section>
</article>
