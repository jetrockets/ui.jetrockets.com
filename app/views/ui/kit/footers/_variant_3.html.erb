            <li><a href="#" class="text-muted-foreground hover:text-foreground text-sm transition">Changelog</a></li>
          </ul>
        </div>

        <div>
          <h3 class="text-foreground text-sm font-semibold">Company</h3>
          <ul class="mt-4 space-y-3">
            <li><a href="#" class="text-muted-foreground hover:text-foreground text-sm transition">About</a></li>
            <li><a href="#" class="text-muted-foreground hover:text-foreground text-sm transition">Blog</a></li>
            <li><a href="#" class="text-muted-foreground hover:text-foreground text-sm transition">Careers</a></li>
            <li><a href="#" class="text-muted-foreground hover:text-foreground text-sm transition">Contact</a></li>
          </ul>
        </div>

        <div>
          <h3 class="text-foreground text-sm font-semibold">Support</h3>
          <ul class="mt-4 space-y-3">
            <li><a href="#" class="text-muted-foreground hover:text-foreground text-sm transition">Help Center</a></li>
