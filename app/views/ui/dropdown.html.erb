<%
  set_meta_tags(
    title: "Dropdown - Rails UI Components",
    description: "Dropdown component for contextual menus and navigation.",
    keywords: "Rails, UI Components, Dropdown"
  )
%>
<% breadcrumb :ui_dropdown %>

<article>
  <%= ui.header do %>
    <%= ui.header_heading do %>
      <%= ui.header_title "Dropdown" %>
      <%= ui.header_subtitle "Dropdown component for contextual menus and navigation." %>
    <% end %>
    <%= ui.header_actions do %>
      <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/dropdown", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
    <% end %>
  <% end %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Example</h2>
    <%= ui.tabs do %>
      <%= ui.tabs_item "Preview", href: ui_dropdown_path, active: !params[:code] %>
      <%= ui.tabs_item "Code", href: ui_dropdown_path(code: true), active: params[:code] %>
    <% end %>

    <div class="flex flex-col gap-2">
      <% unless params[:code] %>
        <%= render "ui/examples/dropdown" %>
      <% else %>
        <%= render_code_example("ui/examples/_dropdown") %>
      <% end %>
    </div>
  </section>
</article>
