<% set_meta_tags(
  title: "Drawer - Rails UI Components",
  description: "Drawer component for sliding panel overlays.",
  keywords: "Rails, UI Components, Drawer"
) %>
<% breadcrumb :ui_drawer %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Drawer" %>
    <%= ui.header_subtitle "Drawer component for sliding panel overlays." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/drawer", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("drawer") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("drawer") %>
  </section>

  <%= render_content_info("drawer") %>
  <%= render_props_table("drawer") %>
  <%= render_subcomponents_table("drawer") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("drawer") %>
  </section>
</article>
