<% set_meta_tags(
  title: "Toggler - Rails UI Components",
  description: "Toggle switch component that enhances the standard Rails check_box with improved styling.",
  keywords: "Rails, UI Components, Form Builder, Toggler"
) %>
<% breadcrumb :ui_form_builders_toggler %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Toggler" %>
    <%= ui.header_subtitle "Toggle switch component that enhances the standard Rails check_box with improved styling." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/lib/form_builders/fields/toggler.rb", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("toggler") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("toggler") %>
  </section>

  <%= render_props_table("toggler") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("toggler") %>
  </section>
</article>
