<% set_meta_tags(
  title: "Flash Message - Rails UI Components",
  description: "Flash Message component for displaying brief notifications.",
  keywords: "Rails, Flash Message, UI Components, Notifications"
) %>
<% breadcrumb :ui_flash_message %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Flash message" %>
    <%= ui.header_subtitle "Display brief notifications to users." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/flash", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("flash") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("flash") %>
  </section>

  <%= render_props_table("flash") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("flash") %>
  </section>
</article>
