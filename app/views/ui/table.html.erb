<% set_meta_tags(
  title: "Table - Rails UI Components",
  description: "Table component for displaying tabular data.",
  keywords: "Rails, UI Components, Table"
) %>
<% breadcrumb :ui_table %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Table" %>
    <%= ui.header_subtitle "Table component for displaying tabular data." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/table", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("table") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("table") %>
  </section>

  <%= render_props_table("table") %>
  <%= render_subcomponents_table("table") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("table") %>
  </section>
</article>
