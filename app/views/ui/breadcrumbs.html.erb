<% set_meta_tags(
  title: "Breadcrumbs - Rails UI Components",
  description: "Breadcrumbs component for navigation hierarchy.",
  keywords: "Rails, UI Components, Breadcrumbs, Navigation"
) %>
<% breadcrumb :ui_breadcrumbs %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Breadcrumbs" %>
    <%= ui.header_subtitle "Navigation breadcrumbs wrapper for Gretel gem." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/breadcrumbs", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("breadcrumbs") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("breadcrumbs") %>
  </section>

  <%= render_content_info("breadcrumbs") %>
  <%= render_props_table("breadcrumbs") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("breadcrumbs") %>
  </section>
</article>
