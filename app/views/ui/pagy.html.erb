<%
  set_meta_tags(
    title: "Pagy - Rails UI Components",
    description: "Pagy component for pagination controls.",
    keywords: "Rails, UI Components, Pagy, Pagination"
  )
%>
<% breadcrumb :ui_pagy %>

<article>
  <%= ui.header do %>
    <%= ui.header_heading do %>
      <%= ui.header_title "Pagy" %>
      <%= ui.header_subtitle "Pagy component for pagination controls." %>
    <% end %>
    <%= ui.header_actions do %>
      <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/pagy", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
    <% end %>
  <% end %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Example</h2>
    <%= ui.tabs do %>
      <%= ui.tabs_item "Preview", href: ui_pagy_path, active: !params[:code] %>
      <%= ui.tabs_item "Code", href: ui_pagy_path(code: true), active: params[:code] %>
    <% end %>

    <div class="flex flex-col gap-2">
      <% unless params[:code] %>
        <%= render "ui/examples/pagy" %>
      <% else %>
        <%= render_code_example("ui/examples/_pagy") %>
      <% end %>
    </div>
  </section>
</article>
