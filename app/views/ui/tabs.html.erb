<% set_meta_tags(
  title: "Tabs - Rails UI Components",
  description: "Tabs component for organizing content into sections.",
  keywords: "Rails, UI Components, Tabs"
) %>
<% breadcrumb :ui_tabs %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Tabs" %>
    <%= ui.header_subtitle "Tabs component for organizing content into sections." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/tabs", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("tabs") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("tabs") %>
  </section>

  <%= render_content_info("tabs") %>
  <%= render_props_table("tabs") %>
  <%= render_subcomponents_table("tabs") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("tabs") %>
  </section>
</article>
