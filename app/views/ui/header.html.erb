<% set_meta_tags(
  title: "Header - Rails UI Components",
  description: "Header component for page titles, subtitles and actions.",
  keywords: "Rails, UI Components, Header, Page Title"
) %>
<% breadcrumb :ui_header %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Header" %>
    <%= ui.header_subtitle "Page header component with title, subtitle and actions." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/header", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("header") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("header") %>
  </section>

  <%= render_props_table("header") %>
  <%= render_subcomponents_table("header") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("header") %>
  </section>
</article>
