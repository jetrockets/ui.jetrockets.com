{
  "name": "jetrockets-ui-autocomplete",
  "displayName": "JetRockets UI Autocomplete",
  "description": "Autocomplete for JetRockets UI components based on component.yml definitions",
  "version": "0.1.0",
  "publisher": "jetrockets",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "JetRockets UI",
      "properties": {
        "jetrocketsUI.componentsPath": {
          "type": "string",
          "default": "app/components/ui",
          "description": "Path to UI components directory"
        },
        "jetrocketsUI.helperPrefix": {
          "type": "string",
          "default": "ui.",
          "description": "Helper prefix that triggers autocomplete"
        }
      }
    }
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "esbuild": "^0.27.4"
  }
}
