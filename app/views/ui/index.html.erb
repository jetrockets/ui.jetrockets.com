<%
  set_meta_tags(
    title: "Rails UI Components",
    description: "A comprehensive Rails 8 component library built with ViewComponent, TailwindCSS 4.0, and Stimulus.",
    keywords: "Rails, UI, Components, ViewComponent, TailwindCSS, Stimulus"
  )
%>
<% breadcrumb :ui %>

<%# Hero %>
<section class="py-12 lg:py-20">
  <div class="mx-auto max-w-3xl text-center">
    <%= ui.badge "Open Source", variant: :info, size: :sm, rounded: true %>
    <h1 class="text-foreground mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
      Rails UI Components
    </h1>
    <p class="text-muted-foreground mx-auto mt-4 max-w-2xl text-lg leading-relaxed">
      A comprehensive component library built with ViewComponent, TailwindCSS 4.0, and Stimulus.
      Copy, paste, and customize — it's your code.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <%= ui.btn url: ui_getting_started_path, size: :lg do %>
        Get Started
        <%= ui.icon "arrow-right", size: 5 %>
      <% end %>
      <%= ui.btn "Browse Components", url: ui_button_path, variant: :outline, size: :lg %>
    </div>
  </div>
</section>

<%# Stats %>
<section class="py-8">
  <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
    <%= ui.stat do %>
      <%= ui.stat_value "29+" %>
      <%= ui.stat_label "UI Components" %>
    <% end %>
    <%= ui.stat do %>
      <%= ui.stat_value "8" %>
      <%= ui.stat_label "Form Fields" %>
    <% end %>
    <%= ui.stat do %>
      <%= ui.stat_value "61+" %>
      <%= ui.stat_label "Kit Blocks" %>
    <% end %>
    <%= ui.stat do %>
      <%= ui.stat_value "9" %>
      <%= ui.stat_label "Block Categories" %>
    <% end %>
  </div>
</section>

<%# Key Technologies %>
<section class="py-12">
  <div class="text-center">
    <h2 class="text-foreground text-2xl font-bold tracking-tight">Built on solid foundations</h2>
    <p class="text-muted-foreground mt-2">Modern stack, battle-tested libraries, zero lock-in.</p>
  </div>

  <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <% [
      { icon: "code-bracket", title: "Rails 7+", desc: "Backend framework with modern features and conventions." },
      { icon: "cube-transparent", title: "ViewComponent", desc: "Component-based architecture for testable, encapsulated views." },
      { icon: "paint-brush", title: "TailwindCSS 4.0", desc: "Utility-first CSS with semantic design tokens and dark mode." },
      { icon: "bolt", title: "Stimulus", desc: "Modest JavaScript for progressive enhancement." },
      { icon: "rocket-launch", title: "Vite", desc: "Lightning-fast builds with HMR for rapid development." },
      { icon: "globe-alt", title: "Turbo", desc: "SPA-like navigation without writing JavaScript." },
    ].each do |item| %>
      <%= ui.card do %>
        <%= ui.card_body class: "flex gap-4" do %>
          <div class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-primary/10">
            <%= ui.icon item[:icon], size: 5, class: "text-primary" %>
          </div>
          <div>
            <h3 class="text-foreground font-semibold"><%= item[:title] %></h3>
            <p class="text-muted-foreground mt-1 text-sm"><%= item[:desc] %></p>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
</section>

<%# What's Inside %>
<section class="py-12">
  <div class="text-center">
    <h2 class="text-foreground text-2xl font-bold tracking-tight">What's inside</h2>
    <p class="text-muted-foreground mt-2">Everything you need to build production-ready Rails applications.</p>
  </div>

  <div class="mt-8 grid gap-6 lg:grid-cols-3">
    <%# Components %>
    <%= ui.card do %>
      <%= ui.card_header do %>
        <%= ui.card_title do %>
          <%= ui.icon "squares-2x2", size: 5, class: "text-primary" %>
          Components
        <% end %>
        <%= ui.card_subtitle "29+ reusable UI components" %>
      <% end %>
      <%= ui.card_body do %>
        <div class="flex flex-wrap gap-1.5">
          <% %w[Button Card Modal Drawer Dropdown Table Tabs Accordion Alert Badge Avatar Tooltip Popover Spinner Stat Timeline Stepper].each do |name| %>
            <%= ui.badge name, size: :xs %>
          <% end %>
        </div>
      <% end %>
      <%= ui.card_footer do %>
        <%= ui.btn "Browse components", variant: :ghost, size: :sm, url: ui_button_path do %>
          Browse components
          <%= ui.icon "arrow-right", size: 4 %>
        <% end %>
      <% end %>
    <% end %>

    <%# Forms %>
    <%= ui.card do %>
      <%= ui.card_header do %>
        <%= ui.card_title do %>
          <%= ui.icon "pencil-square", size: 5, class: "text-primary" %>
          Form Builder
        <% end %>
        <%= ui.card_subtitle "8 form fields with validation" %>
      <% end %>
      <%= ui.card_body do %>
        <div class="flex flex-wrap gap-1.5">
          <% %w[TextField TextArea Select Choices Checkbox RadioButton Toggler Easepick].each do |name| %>
            <%= ui.badge name, size: :xs %>
          <% end %>
        </div>
      <% end %>
      <%= ui.card_footer do %>
        <%= ui.btn variant: :ghost, size: :sm, url: ui_form_builders_text_field_path do %>
          Browse form fields
          <%= ui.icon "arrow-right", size: 4 %>
        <% end %>
      <% end %>
    <% end %>

    <%# Kit %>
    <%= ui.card class: "border-primary/30" do %>
      <%= ui.card_header do %>
        <%= ui.card_title do %>
          <%= ui.icon "rectangle-group", size: 5, class: "text-primary" %>
          UI Kit
          <%= ui.badge "New", size: :xs, variant: :success %>
        <% end %>
        <%= ui.card_subtitle "61+ ready-made page blocks" %>
      <% end %>
      <%= ui.card_body do %>
        <div class="flex flex-wrap gap-1.5">
          <% ["Hero Sections", "Features", "Pricing", "CTA", "Testimonials", "Forms", "Tables", "Footers", "Team"].each do |name| %>
            <%= ui.badge name, size: :xs %>
          <% end %>
        </div>
      <% end %>
      <%= ui.card_footer do %>
        <%= ui.btn variant: :ghost, size: :sm, url: ui_kit_index_path do %>
          Browse blocks
          <%= ui.icon "arrow-right", size: 4 %>
        <% end %>
      <% end %>
    <% end %>
  </div>
</section>

<%# VS Code Extension %>
<section class="py-12">
  <div class="text-center">
    <h2 class="text-foreground text-2xl font-bold tracking-tight">Developer experience</h2>
    <p class="text-muted-foreground mt-2">Tools that make working with components a breeze.</p>
  </div>

  <div class="mt-8">
    <%= ui.card class: "border-primary/30" do %>
      <%= ui.card_body class: "flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between lg:p-8 p-6" do %>
        <div class="flex gap-4">
          <div class="flex size-12 shrink-0 items-center justify-center rounded-lg bg-primary/10">
            <%= ui.icon "code-bracket-square", size: 6, class: "text-primary" %>
          </div>
          <div>
            <h3 class="text-foreground text-lg font-semibold">
              VS Code Extension
              <%= ui.badge "New", size: :xs, variant: :success %>
            </h3>
            <p class="text-muted-foreground mt-1 text-sm">
              Autocomplete, prop suggestions, enum values, and hover documentation for all components — right in your editor.
            </p>
          </div>
        </div>
        <%= ui.btn url: ui_vscode_path, variant: :outline do %>
          Learn more
          <%= ui.icon "arrow-right", size: 4 %>
        <% end %>
      <% end %>
    <% end %>
  </div>
</section>

<%# Getting Started Steps %>
<section class="py-12">
  <div class="text-center">
    <h2 class="text-foreground text-2xl font-bold tracking-tight">Get started in minutes</h2>
    <p class="text-muted-foreground mt-2">Three simple steps to start building.</p>
  </div>

  <div class="mt-8">
    <%= ui.stepper do %>
      <%= ui.stepper_step "Read the guide", status: :current, description: "Learn how to install and configure" %>
      <%= ui.stepper_step "Explore components", status: :pending, description: "Browse the sidebar for examples" %>
      <%= ui.stepper_step "Copy & build", status: :pending, description: "Paste into your project and ship" %>
    <% end %>
  </div>

  <div class="mt-8 flex justify-center">
    <%= ui.btn url: ui_getting_started_path, size: :lg do %>
      Read Getting Started
      <%= ui.icon "arrow-right", size: 5 %>
    <% end %>
  </div>
</section>
