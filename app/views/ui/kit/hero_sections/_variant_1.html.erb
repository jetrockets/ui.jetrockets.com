<%# Variant 1: Centered simple — centered text, headline, subtitle, 2 CTAs, no image %>
<section class="bg-background py-20 lg:py-32">
  <div class="mx-auto max-w-3xl px-6 text-center">
    <h1 class="text-foreground text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
      Build faster, ship sooner
    </h1>
    <p class="text-muted-foreground mx-auto mt-6 max-w-2xl text-lg sm:text-xl leading-relaxed">
      The modern toolkit for teams who want to move fast without breaking things.
      Design, develop, and deploy with confidence.
    </p>
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <%= ui.btn size: :lg, url: "#" do %>
        Get started free
        <%= ui.icon "arrow-right", size: 5 %>
      <% end %>
      <%= ui.btn "See how it works", variant: :outline, size: :lg, url: "#" %>
    </div>
  </div>
</section>
