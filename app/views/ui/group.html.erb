<%
  set_meta_tags(
    title: "Group - Rails UI Components",
    description: "Group component for grouping related elements together.",
    keywords: "Rails, UI Components, Group"
  )
%>
<% breadcrumb :ui_group %>

<article>
  <header class="header">
    <div class="header__heading">
      <h1 class="header__title">Group</h1>
      <p class="header__subtitle">
        Group component for grouping related elements together.
      </p>
    </div>

    <div class="header__actions">
      <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/group", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
    </div>
  </header>

  <section>
    <h2 class="h3">Example</h2>
    <%= turbo_frame_tag :ui_group, data: { turbo_action: :advance }, target: :_top do %>
      <%= ui.tabs class: "mb-6" do %>
        <%= ui.tabs_item title: "Preview", href: ui_group_path, data: { turbo_frame: :ui_group }, active: !params[:code] %>
        <%= ui.tabs_item title: "Code", href: ui_group_path(code: true), data: { turbo_frame: :ui_group }, active: params[:code] %>
      <% end %>

      <div class="flex flex-col gap-2">
        <% unless params[:code] %>
          <%= render "ui/examples/group" %>
        <% else %>
          <%= render_code_example("ui/examples/_group") %>
        <% end %>
      </div>
    <% end %>
  </section>
</article>
