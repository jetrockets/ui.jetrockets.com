<%
  set_meta_tags(
    title: "Tabs - Rails UI Components",
    description: "Tabs component for organizing content into sections.",
    keywords: "Rails, UI Components, Tabs"
  )
%>
<% breadcrumb :ui_tabs %>

<article>
  <header class="header">
    <div class="header__heading">
      <h1 class="header__title">Tabs</h1>
      <p class="header__subtitle">
        Tabs component for organizing content into sections.
      </p>
    </div>

    <div class="header__actions">
      <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/tabs", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
    </div>
  </header>

  <section>
    <h2 class="h3">Example</h2>
    <%= turbo_frame_tag :ui_tabs, data: { turbo_action: :advance }, target: :_top do %>
      <%= ui.tabs class: "mb-6" do %>
        <%= ui.tabs_item title: "Preview", href: ui_tabs_path, data: { turbo_frame: :ui_tabs }, active: !params[:code] %>
        <%= ui.tabs_item title: "Code", href: ui_tabs_path(code: true), data: { turbo_frame: :ui_tabs }, active: params[:code] %>
      <% end %>

      <div class="flex flex-col gap-2">
        <% unless params[:code] %>
          <%= render "ui/examples/tabs" %>
        <% else %>
          <%= render_code_example("ui/examples/_tabs") %>
        <% end %>
      </div>
    <% end %>
  </section>
</article>
