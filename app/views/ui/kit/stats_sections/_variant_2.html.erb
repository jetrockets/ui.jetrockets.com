<%# Variant 2: With icons — stats with icons above each number %>
<section class="bg-background py-16 lg:py-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <%= ui.badge "By the numbers", variant: :info, rounded: true %>
      <h2 class="text-foreground mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
        Built for scale, designed for speed
      </h2>
    </div>

    <div class="mt-16 grid grid-cols-2 gap-8 lg:grid-cols-4">
      <% [
        { icon: "users", value: "50,000+", label: "Active users" },
        { icon: "globe-alt", value: "120+", label: "Countries" },
        { icon: "clock", value: "99.9%", label: "Uptime" },
        { icon: "chat-bubble-left-right", value: "4.9/5", label: "Customer rating" }
      ].each do |stat| %>
        <div class="flex flex-col items-center text-center">
          <div class="flex size-12 items-center justify-center rounded-lg bg-primary/10">
            <%= ui.icon stat[:icon], size: 6, class: "text-primary" %>
          </div>
          <p class="text-foreground mt-4 text-3xl font-bold tracking-tight sm:text-4xl"><%= stat[:value] %></p>
          <p class="text-muted-foreground mt-2 text-sm font-medium"><%= stat[:label] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>
