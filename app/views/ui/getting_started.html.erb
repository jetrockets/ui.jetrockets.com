<%
  set_meta_tags(
    title: "Getting Started - Rails UI Components",
    description: "Learn how to install, use, and customize Rails UI components in your projects.",
    keywords: "Rails, UI, Components, Installation, Usage, Getting Started"
  )
%>
<% breadcrumb :ui_getting_started %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Getting Started" %>
    <%= ui.header_subtitle "Learn how to install, use, and customize Rails UI components in your projects." %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%# Requirements %>
  <section>
    <h2 class="h2 mb-4">Requirements</h2>
    <div class="grid gap-4 md:grid-cols-2">
      <%= ui.card do %>
        <%= ui.card_header do %>
          <%= ui.card_title do %>
            <%= ui.icon "server-stack", size: 5, class: "text-primary" %>
            Backend
          <% end %>
        <% end %>
        <%= ui.card_body do %>
          <div class="flex flex-col gap-2">
            <% [
              { name: "Ruby", version: "3.2.3+", icon: "check-circle" },
              { name: "Rails", version: "7.0.8+", icon: "check-circle" },
              { name: "ViewComponent", version: "gem", icon: "check-circle" },
            ].each do |req| %>
              <div class="flex items-center gap-2">
                <%= ui.icon req[:icon], size: 4, class: "text-success" %>
                <span class="text-sm"><strong class="text-foreground"><%= req[:name] %></strong> <span class="text-muted-foreground"><%= req[:version] %></span></span>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>

      <%= ui.card do %>
        <%= ui.card_header do %>
          <%= ui.card_title do %>
            <%= ui.icon "globe-alt", size: 5, class: "text-primary" %>
            Frontend
          <% end %>
        <% end %>
        <%= ui.card_body do %>
          <div class="flex flex-col gap-2">
            <% [
              { name: "Node.js", version: "18+", icon: "check-circle" },
              { name: "Vite", version: "asset compilation", icon: "check-circle" },
              { name: "TailwindCSS", version: "4.0", icon: "check-circle" },
            ].each do |req| %>
              <div class="flex items-center gap-2">
                <%= ui.icon req[:icon], size: 4, class: "text-success" %>
                <span class="text-sm"><strong class="text-foreground"><%= req[:name] %></strong> <span class="text-muted-foreground"><%= req[:version] %></span></span>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </section>

  <%# Installation Steps %>
  <section>
    <h2 class="h2 mb-6">Installation</h2>

    <div class="flex flex-col gap-8">
      <%# Step 1 %>
      <%= ui.card do %>
        <%= ui.card_header do %>
          <%= ui.card_title do %>
            <span class="flex size-6 items-center justify-center rounded-full bg-primary text-xs font-bold text-primary-foreground">1</span>
            Add Required Gems
          <% end %>
        <% end %>
        <%= ui.card_body do %>
          <pre><code># Gemfile
gem 'view_component'
gem 'vite_rails'
gem 'turbo-rails'

# Optional — enhanced functionality
gem 'pagy', '~> 9.3.4' # Pagination
gem 'gretel' # Breadcrumbs
gem 'meta-tags' # SEO meta tags
gem 'image_processing', '~> 1.2' # Image uploads
gem 'shrine', '~> 3.0' # File uploads</code></pre>
        <% end %>
      <% end %>

      <%# Step 2 %>
      <%= ui.card do %>
        <%= ui.card_header do %>
          <%= ui.card_title do %>
            <span class="flex size-6 items-center justify-center rounded-full bg-primary text-xs font-bold text-primary-foreground">2</span>
            Add Frontend Dependencies
          <% end %>
        <% end %>
        <%= ui.card_body do %>
          <pre><code># package.json — dependencies
"@hotwired/stimulus": "^3.2.2",
"@hotwired/turbo-rails": "^8.0.2",
"choices.js": "^11.1.0",
"stimulus-textarea-autogrow": "^4.1.0",
"stimulus-use": "^0.52.2"

# devDependencies
"@tailwindcss/vite": "^4.0.6",
"tailwindcss": "^4.0.6",
"vite": "^7.1.7",
"vite-plugin-rails": "^0.5.0"</code></pre>
        <% end %>
      <% end %>

      <%# Step 3 %>
      <%= ui.card do %>
        <%= ui.card_header do %>
          <%= ui.card_title do %>
            <span class="flex size-6 items-center justify-center rounded-full bg-primary text-xs font-bold text-primary-foreground">3</span>
            Install & Run
          <% end %>
        <% end %>
        <%= ui.card_body do %>
          <pre><code>bundle install && yarn install

# Start development
bin/rails server   # Rails server
yarn dev           # Vite dev server</code></pre>
          <div class="mt-4">
            <%= ui.alert variant: :info do %>
              <%= ui.alert_title "Tip" %>
              <%= ui.alert_description do %>
                Use <%= link_to "Overmind", "https://github.com/DarthSim/overmind", target: "_blank", rel: "noopener noreferrer", class: "link" %>
                with <code class="text-xs">Procfile.dev</code> to start everything with a single command.
              <% end %>
            <% end %>
          </div>
        <% end %>
      <% end %>

      <%# Step 4 %>
      <%= ui.card do %>
        <%= ui.card_header do %>
          <%= ui.card_title do %>
            <span class="flex size-6 items-center justify-center rounded-full bg-primary text-xs font-bold text-primary-foreground">4</span>
            Copy Components
          <% end %>
        <% end %>
        <%= ui.card_body do %>
          <div class="mb-4">
            <%= ui.alert variant: :info do %>
              <%= ui.alert_title "Recommended" %>
              <%= ui.alert_description "Clone the full template for best results — all dependencies and configs are already wired up." %>
            <% end %>
          </div>
          <p class="text-muted-foreground mb-4 text-sm">Or copy only what you need:</p>
          <div class="flex flex-col gap-3">
            <% [
              { path: "app/components/ui/", desc: "UI component classes and templates" },
              { path: "app/assets/controllers/", desc: "Stimulus controllers" },
              { path: "app/assets/stylesheets/components/", desc: "Component styles" },
              { path: "app/lib/form_builders/", desc: "Custom form builder" },
            ].each do |item| %>
              <div class="flex items-start gap-3 rounded-lg bg-muted/50 p-3">
                <%= ui.icon "folder", size: 5, class: "mt-0.5 text-primary shrink-0" %>
                <div>
                  <code class="text-sm font-medium text-foreground"><%= item[:path] %></code>
                  <p class="text-muted-foreground text-xs"><%= item[:desc] %></p>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </section>

  <%# Component Structure %>
  <section>
    <h2 class="h2 mb-4">Component Structure</h2>
    <p class="text-muted-foreground mb-4">Each component follows a consistent pattern:</p>
    <%= ui.card do %>
      <%= ui.card_body do %>
        <pre><code>app/components/ui/[component_name]/
├── component.rb              # Main component class
├── component.html.erb        # Template (when needed)
├── component.css             # Component-specific styles
├── component_controller.js   # Stimulus controller (when needed)
├── header_component.rb       # Sub-component (flat structure)
└── body_component.rb         # Sub-component (flat structure)</code></pre>
      <% end %>
    <% end %>
  </section>

  <%# What's Next %>
  <section>
    <h2 class="h2 mb-4">What's next?</h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% [
        { title: "Good to Know", desc: "Architecture decisions and best practices", url: ui_good_to_know_path, icon: "light-bulb" },
        { title: "Components", desc: "Browse all 29+ UI components", url: ui_button_path, icon: "squares-2x2" },
        { title: "UI Kit", desc: "61+ copy-paste page blocks", url: ui_kit_index_path, icon: "rectangle-group" },
      ].each do |item| %>
        <%= link_to item[:url], class: "group" do %>
          <%= ui.card class: "h-full transition-shadow hover:shadow-md" do %>
            <%= ui.card_body class: "flex gap-4" do %>
              <div class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-primary/10">
                <%= ui.icon item[:icon], size: 5, class: "text-primary" %>
              </div>
              <div>
                <h3 class="text-foreground font-semibold group-hover:text-primary transition-colors"><%= item[:title] %></h3>
                <p class="text-muted-foreground mt-1 text-sm"><%= item[:desc] %></p>
              </div>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </section>
</article>
