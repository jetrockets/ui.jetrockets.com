<% set_meta_tags(title: "Remember Me") %>

<%= ui.modal(title: "Remember Me", size: :lg) do %>
  <%= ui.modal_body do %>
    <%= form_with url: rodauth.remember_path, method: :post, class: "form" do |form| %>
      <%= f.group class: "flex flex-col gap-2" do %>
        <%= form.radio_button rodauth.remember_param, rodauth.remember_remember_param_value, id: "remember-remember", label: rodauth.remember_remember_label %>
        <%= form.radio_button rodauth.remember_param, rodauth.remember_forget_param_value, id: "remember-forget", label: rodauth.remember_forget_label %>
        <%= form.radio_button rodauth.remember_param, rodauth.remember_disable_param_value, id: "remember-disable", label: rodauth.remember_disable_label %>
      <% end %>

      <div class="form__actions">
        <%= form.submit rodauth.remember_button, block: true %>
      </div>
    <% end %>
  <% end %>
<% end %>
