<%# Variant 5: Horizontal cards -- Each plan as a horizontal card with features listed inline %>
<section class="bg-background py-16 lg:py-24">
  <div class="mx-auto max-w-5xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-foreground text-3xl font-bold tracking-tight sm:text-4xl">
        Pick your plan
      </h2>
      <p class="text-muted-foreground mt-4 text-lg leading-relaxed">
        Flexible plans designed to grow with your business. Upgrade or downgrade at any time.
      </p>
    </div>

    <div class="mt-12 flex flex-col gap-6">
      <%# Hobby Plan %>
      <%= ui.card do %>
        <%= ui.card_body class: "p-6 lg:p-8" do %>
          <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-8">
              <div class="min-w-[140px]">
                <h3 class="text-foreground text-lg font-semibold">Hobby</h3>
                <div class="mt-1 flex items-baseline gap-1">
                  <span class="text-foreground text-3xl font-bold tracking-tight">$0</span>
                  <span class="text-muted-foreground text-sm">/mo</span>
                </div>
              </div>
              <div class="border-border lg:border-l lg:pl-8">
                <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">3 projects</span>
                  </li>
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">1 GB storage</span>
                  </li>
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">Community support</span>
                  </li>
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">Basic analytics</span>
                  </li>
                </ul>
              </div>
            </div>
            <div class="shrink-0">
              <%= ui.btn "Get started", variant: :outline, url: "#" %>
            </div>
          </div>
        <% end %>
      <% end %>

      <%# Pro Plan (Highlighted) %>
      <%= ui.card class: "border-primary ring-primary/20 ring-2" do %>
        <%= ui.card_body class: "p-6 lg:p-8" do %>
          <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-8">
              <div class="min-w-[140px]">
                <div class="flex items-center gap-2">
                  <h3 class="text-foreground text-lg font-semibold">Pro</h3>
                  <%= ui.badge "Popular", variant: :default, size: :xs, rounded: true %>
                </div>
                <div class="mt-1 flex items-baseline gap-1">
                  <span class="text-foreground text-3xl font-bold tracking-tight">$29</span>
                  <span class="text-muted-foreground text-sm">/mo</span>
                </div>
              </div>
              <div class="border-border lg:border-l lg:pl-8">
                <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">Unlimited projects</span>
                  </li>
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">50 GB storage</span>
                  </li>
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">Priority support</span>
                  </li>
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">Advanced analytics</span>
                  </li>
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">Custom domains</span>
                  </li>
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">API access</span>
                  </li>
                </ul>
              </div>
            </div>
            <div class="shrink-0">
              <%= ui.btn "Start free trial", url: "#" %>
            </div>
          </div>
        <% end %>
      <% end %>

      <%# Team Plan %>
      <%= ui.card do %>
        <%= ui.card_body class: "p-6 lg:p-8" do %>
          <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-8">
              <div class="min-w-[140px]">
                <h3 class="text-foreground text-lg font-semibold">Team</h3>
                <div class="mt-1 flex items-baseline gap-1">
                  <span class="text-foreground text-3xl font-bold tracking-tight">$79</span>
                  <span class="text-muted-foreground text-sm">/mo</span>
                </div>
              </div>
              <div class="border-border lg:border-l lg:pl-8">
                <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">Unlimited everything</span>
                  </li>
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">200 GB storage</span>
                  </li>
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">Dedicated support</span>
                  </li>
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">SSO & audit logs</span>
                  </li>
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">Custom contracts</span>
                  </li>
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">SLA guarantee</span>
                  </li>
                </ul>
              </div>
            </div>
            <div class="shrink-0">
              <%= ui.btn "Contact sales", variant: :outline, url: "#" %>
            </div>
          </div>
        <% end %>
      <% end %>

      <%# Enterprise Plan %>
      <%= ui.card do %>
        <%= ui.card_body class: "p-6 lg:p-8" do %>
          <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-8">
              <div class="min-w-[140px]">
                <h3 class="text-foreground text-lg font-semibold">Enterprise</h3>
                <div class="mt-1">
                  <span class="text-foreground text-2xl font-bold tracking-tight">Custom</span>
                </div>
              </div>
              <div class="border-border lg:border-l lg:pl-8">
                <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">Everything in Team</span>
                  </li>
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">Unlimited storage</span>
                  </li>
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">On-premise deployment</span>
                  </li>
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">Custom integrations</span>
                  </li>
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">Dedicated engineer</span>
                  </li>
                  <li class="flex items-center gap-1.5">
                    <%= ui.icon "check", size: 4, class: "text-primary shrink-0" %>
                    <span class="text-foreground">99.99% SLA</span>
                  </li>
                </ul>
              </div>
            </div>
            <div class="shrink-0">
              <%= ui.btn "Talk to us", variant: :outline, url: "#" %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</section>
