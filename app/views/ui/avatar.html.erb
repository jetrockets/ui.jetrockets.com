<% set_meta_tags(
  title: "Avatar - Rails UI Components",
  description: "Display user profile images and initials.",
  keywords: "Rails, UI Components, Avatar"
) %>
<% breadcrumb :ui_avatar %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Avatar" %>
    <%= ui.header_subtitle "Display user profile images and initials." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/components/ui/avatar", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("avatar") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("avatar") %>
  </section>

  <%= render_content_info("avatar") %>
  <%= render_props_table("avatar") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("avatar") %>
  </section>
</article>
