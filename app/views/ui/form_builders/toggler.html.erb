<%
  set_meta_tags(
    title: "Toggler - Rails UI Components",
    description: "Toggle switch component with enhanced styling and accessibility features.",
    keywords: "Rails, UI Components, Toggle, Switch, Form"
  )
%>
<% breadcrumb :ui_form_builders_toggler %>

<article>
  <%= ui.header do %>
    <%= ui.header_heading do %>
      <%= ui.header_title do %>Rails <code class="px-1 text-3xl bg-yellow-100">check_box</code> as a Toggler<% end %>
      <%= ui.header_subtitle do %>A toggle switch component that enhances the standard Rails <code>check_box</code> with improved styling feature.<% end %>
    <% end %>
    <%= ui.header_actions do %>
      <%= link_to "View on GitHub", "https://github.com/jetrockets/ui.jetrockets.com/blob/main/app/lib/form_builders/fields/toggler.rb", class: "btn btn-secondary", target: "_blank", rel: "noopener noreferrer" %>
    <% end %>
  <% end %>

  <section class="mb-12">
    <%= ui.card do %>
      <%= ui.card_header align: :left do %>
        <%= ui.card_title do %>Basic Toggler<% end %>
      <% end %>

      <%= ui.card_body do %>
        <%= form_with url: root_path do |f| %>
          <%= f.group do %>
            <%= f.toggler :dark_mode %>
          <% end %>

          <%= f.group do %>
            <%= f.toggler :notifications, hint: "Here you can have a hint" %>
          <% end %>
        <% end %>
      <% end %>

      <%= ui.card_footer do %>
        <pre class="w-full"><code>&lt;%= f.toggler :dark_mode %&gt;
&lt;%= f.toggler :dark_mode, hint: "Here you can have a hint" %&gt;</code></pre>
      <% end %>
    <% end %>
  </section>
</article>
