<%= ui.table size: :md, hovered: true do %>
  <%= ui.table_thead do %>
    <%= ui.table_tr do %>
      <%= ui.table_th "Payment" %>
      <%= ui.table_th "Status" %>
      <%= ui.table_th "Amount" %>
      <%= ui.table_th "Created At" %>
      <%= ui.table_th "Actions" %>
    <% end %>
  <% end %>

  <%= ui.table_tbody do %>
    <% 2.times.each do |index| %>
      <%= ui.table_tr do %>
        <%= ui.table_td "Payment Name", class: "w-4/12" %>
        <%= ui.table_td { ui.badge title: "Paid", variant: :green } %>
        <%= ui.table_td number_to_currency(1200), class: "whitespace-nowrap" %>
        <%= ui.table_td I18n.l(Time.zone.now, format: :full_month), class: "whitespace-nowrap" %>
        <%= ui.table_td(actions: true) do %>
          <%= ui.group do %>
            <%= ui.btn "Show", size: :sm, variant: :outline %>
            <%= ui.btn "Edit", size: :sm, variant: :outline %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= ui.table_tfoot do %>
    <%= ui.table_tr do %>
      <%= ui.table_td "Total", colspan: 2 %>
      <%= ui.table_td number_to_currency(2400), colspan: 3 %>
    <% end %>
  <% end %>
<% end %>

<%= ui.table size: :xs, bordered: true, hovered: true do %>
  <%= ui.table_thead do %>
    <%= ui.table_tr do %>
      <%= ui.table_th(sticky: :left) { "Payment" } %>
      <%= ui.table_th { "Status" } %>
      <%= ui.table_th { "Amount" } %>
      <%= ui.table_th { "Created At" } %>
      <%= ui.table_th { "Actions" } %>
    <% end %>
  <% end %>

  <%= ui.table_tbody do %>
    <% 2.times.each do |index| %>
      <%= ui.table_tr do %>
        <%= ui.table_td "Payment Name", sticky: :left, class: "w-4/12" %>
        <%= ui.table_td ui.badge(title: "Paid", variant: :green) %>
        <%= ui.table_td number_to_currency(1200), class: "whitespace-nowrap" %>
        <%= ui.table_td I18n.l(Time.zone.now, format: :full_month), class: "whitespace-nowrap" %>
        <%= ui.table_td(actions: true) do %>
          <%= ui.group do %>
            <%= ui.btn "Show", size: :xs, variant: :outline %>
            <%= ui.btn "Edit", size: :xs, variant: :outline %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= ui.table_tfoot do %>
    <%= ui.table_tr do %>
      <%= ui.table_td "Total", colspan: 2 %>
      <%= ui.table_td number_to_currency(2400), colspan: 3 %>
    <% end %>
  <% end %>
<% end %>
