<%
  set_meta_tags(
    title: "Rails UI Components",
    description: "A comprehensive Rails 7 component library built with ViewComponent, TailwindCSS 4.0, and Stimulus.",
    keywords: "Rails, UI, Components, ViewComponent, TailwindCSS, Stimulus"
  )
%>
<% breadcrumb :ui %>

<article>
  <%= ui.header do %>
    <%= ui.header_heading do %>
      <%= ui.header_title "Rails UI Components" %>
      <%= ui.header_subtitle "A comprehensive Rails 7 component library built with ViewComponent, TailwindCSS 4.0, and Stimulus. This template provides a complete set of reusable UI components that developers can copy and customize for their projects." %>
    <% end %>
  <% end %>

  <section class="flex flex-col gap-4 mb-12">
    <h2 class="h2">Key Technologies</h2>

    <div class="grid gap-4 lg:grid-cols-2">
      <%= ui.card do %>
        <%= ui.card_header bordered: false do %>
          <%= ui.card_title do %>Rails 7 or higher<% end %>
        <% end %>
        <%= ui.card_body do %>
          <p>
            <%= link_to "Backend framework", "https://rubyonrails.org/", target: "_blank", rel: "noopener noreferrer", class: "link" %>
            with modern features
          </p>
        <% end %>
      <% end %>

      <%= ui.card do %>
        <%= ui.card_header bordered: false do %>
          <%= ui.card_title do %>ViewComponent<% end %>
        <% end %>
        <%= ui.card_body do %>
          <p>
            <%= link_to "Component-based architecture", "https://viewcomponent.org/", target: "_blank", rel: "noopener noreferrer", class: "link" %>
            for views
          </p>
        <% end %>
      <% end %>

      <%= ui.card do %>
        <%= ui.card_header bordered: false do %>
          <%= ui.card_title do %>TailwindCSS 4.0<% end %>
        <% end %>
        <%= ui.card_body do %>
          <p>
            <%= link_to "Utility-first CSS framework", "https://tailwindcss.com/", target: "_blank", rel: "noopener noreferrer", class: "link" %>
            for rapid UI development
          </p>
        <% end %>
      <% end %>

      <%= ui.card do %>
        <%= ui.card_header bordered: false do %>
          <%= ui.card_title do %>Stimulus<% end %>
        <% end %>
        <%= ui.card_body do %>
          <p>
            <%= link_to "Modest JavaScript framework", "https://stimulus.hotwired.dev/", target: "_blank", rel: "noopener noreferrer", class: "link" %>
            for enhancing HTML with minimal JavaScript
          </p>
        <% end %>
      <% end %>

      <%= ui.card do %>
        <%= ui.card_header bordered: false do %>
          <%= ui.card_title do %>Vite<% end %>
        <% end %>
        <%= ui.card_body do %>
          <p>
            <%= link_to "Fast build tool", "https://vitejs.dev/", target: "_blank", rel: "noopener noreferrer", class: "link" %>
            for frontend assets
          </p>
        <% end %>
      <% end %>
    </div>
  </section>

  <section class="flex flex-col gap-4 my-12">
    <h2 class="h2">Next Steps</h2>

    <div class="flex flex-col gap-3">
      <div class="flex items-center gap-3">
        <div class="flex items-center justify-center text-sm font-semibold text-white rounded-full size-8 bg-primary shrink-0">1</div>
        <div>
          <%= link_to "Read Getting Started guide", ui_getting_started_path, class: "link" %> to learn how to use and customize components.
        </div>
      </div>

      <div class="flex items-center gap-3">
        <div class="flex items-center justify-center text-sm font-semibold text-white rounded-full size-8 bg-primary shrink-0">2</div>
        <div>
          Explore the <strong>Components</strong> section in the sidebar to see detailed examples and usage patterns.
        </div>
      </div>

      <div class="flex items-center gap-3">
        <div class="flex items-center justify-center text-sm font-semibold text-white rounded-full size-8 bg-primary shrink-0">3</div>
        <div>
          Check <%= link_to "Good to know", ui_good_to_know_path, class: "link" %> for best practices and architectural decisions.
        </div>
      </div>
    </div>
  </section>
</article>
