<%
  set_meta_tags(
    title: "Form Builder - Rails UI Components",
    description: "Form Builder component with enhanced form controls.",
    keywords: "Rails, UI Components, Form Builder"
  )
%>
<% breadcrumb :ui_form_builders_default %>

<article>
  <%= ui.header do %>
    <%= ui.header_heading do %>
      <%= ui.header_title "Default Form Builder" %>
      <%= ui.header_subtitle "Enhanced Rails form builder with automatic HTML structuring, with label, hint, error handling, consistent styling, and improved accessibility features." %>
    <% end %>
    <%= ui.header_actions do %>
      <%= link_to "View on GitHub", "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/lib/form_builders/default_form_builder.rb", class: "btn btn-secondary", target: "_blank", rel: "noopener noreferrer" %>
    <% end %>
  <% end %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Example</h2>
    <%= ui.tabs do %>
      <%= ui.tabs_item "Preview", href: ui_form_builders_default_path, active: !params[:code] %>
      <%= ui.tabs_item "Code", href: ui_form_builders_default_path(code: true), active: params[:code] %>
    <% end %>

    <div class="flex flex-col gap-2">
      <% unless params[:code] %>
        <%= render "ui/form_builders/examples/default_form_builder" %>
      <% else %>
        <%= render_code_example("ui/form_builders/examples/_default_form_builder") %>
      <% end %>
    </div>
  </section>
</article>
