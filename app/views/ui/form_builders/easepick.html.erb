<% set_meta_tags(
  title: "Easepick - Rails UI Components",
  description: "Enhanced date picker field with powerful calendar functionality using the Easepick library.",
  keywords: "Rails, UI Components, Form Builder, Easepick, Date Picker"
) %>
<% breadcrumb :ui_form_builders_easepick %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "Easepick" %>
    <%= ui.header_subtitle "Enhanced date picker field with powerful calendar functionality using the Easepick library." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/lib/form_builders/fields/easepick.rb", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("easepick") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("easepick") %>
  </section>

  <%= render_props_table("easepick") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("easepick") %>
  </section>
</article>
