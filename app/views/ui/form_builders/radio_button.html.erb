<% set_meta_tags(
  title: "RadioButton - Rails UI Components",
  description: "Enhanced radio button field with consistent styling, hint support, and improved accessibility.",
  keywords: "Rails, UI Components, Form Builder, RadioButton"
) %>
<% breadcrumb :ui_form_builders_radio_button %>

<%= ui.header do %>
  <%= ui.header_heading do %>
    <%= ui.header_title "RadioButton" %>
    <%= ui.header_subtitle "Enhanced radio button field with consistent styling, hint support, and improved accessibility for single-choice selection." %>
  <% end %>
  <%= ui.header_actions do %>
    <%= ui.btn "View on GitHub", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/lib/form_builders/fields/radio_button.rb", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
  <% end %>
<% end %>

<article class="flex flex-col gap-12">
  <%= render_component_preview("radio_button") %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Usage</h2>
    <%= render_component_usage("radio_button") %>
  </section>

  <%= render_props_table("radio_button") %>

  <section class="flex flex-col gap-6">
    <h2 class="h3">Examples</h2>
    <%= render_component_examples("radio_button") %>
  </section>
</article>
