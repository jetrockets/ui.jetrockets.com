<%
  set_meta_tags(
    title: "Colors - Rails UI Components",
    description: "Semantic color tokens and design system theme.",
    keywords: "Rails, UI Components, Colors, Design Tokens, Semantic Colors"
  )
%>
<% breadcrumb :ui_colors %>

<article>
  <%= ui.header do %>
    <%= ui.header_heading do %>
      <%= ui.header_title "Colors" %>
      <%= ui.header_subtitle "Semantic color tokens and design system theme." %>
    <% end %>
    <%= ui.header_actions do %>
      <%= ui.btn "View theme.css", url: "https://github.com/jetrockets/ui.jetrockets.com/tree/main/app/assets/stylesheets/tailwind/theme.css", variant: :secondary, target: "_blank", rel: "noopener noreferrer" %>
    <% end %>
  <% end %>

  <section class="flex flex-col gap-4">
    <h2 class="h3">Semantic Tokens</h2>
    <p style="color: var(--color-muted-foreground)">Use semantic tokens instead of raw color values. They adapt to theme changes automatically.</p>
    <pre><code>/* CSS Theme - use in custom styles */
background-color: var(--color-primary);
color: var(--color-foreground);
border-color: var(--color-border);</code></pre>
  </section>

  <section class="flex flex-col gap-6 mt-10">
    <h2 class="h3">Layout</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
      <div class="flex flex-col">
        <div class="h-16 rounded-lg shadow-sm border" style="background-color: var(--color-background); border-color: var(--color-border)"></div>
        <div class="mt-2">
          <p class="text-sm font-medium" style="color: var(--color-foreground)">Background</p>
          <p class="text-xs font-mono" style="color: var(--color-muted-foreground)">--color-background</p>
        </div>
      </div>
      <div class="flex flex-col">
        <div class="h-16 rounded-lg shadow-sm" style="background-color: var(--color-foreground)"></div>
        <div class="mt-2">
          <p class="text-sm font-medium" style="color: var(--color-foreground)">Foreground</p>
          <p class="text-xs font-mono" style="color: var(--color-muted-foreground)">--color-foreground</p>
        </div>
      </div>
      <div class="flex flex-col">
        <div class="h-16 rounded-lg shadow-sm border" style="background-color: var(--color-card); border-color: var(--color-border)"></div>
        <div class="mt-2">
          <p class="text-sm font-medium" style="color: var(--color-foreground)">Card</p>
          <p class="text-xs font-mono" style="color: var(--color-muted-foreground)">--color-card</p>
        </div>
      </div>
      <div class="flex flex-col">
        <div class="h-16 rounded-lg shadow-sm" style="background-color: var(--color-muted)"></div>
        <div class="mt-2">
          <p class="text-sm font-medium" style="color: var(--color-foreground)">Muted</p>
          <p class="text-xs font-mono" style="color: var(--color-muted-foreground)">--color-muted</p>
        </div>
      </div>
      <div class="flex flex-col">
        <div class="h-16 rounded-lg shadow-sm" style="background-color: var(--color-border)"></div>
        <div class="mt-2">
          <p class="text-sm font-medium" style="color: var(--color-foreground)">Border</p>
          <p class="text-xs font-mono" style="color: var(--color-muted-foreground)">--color-border</p>
        </div>
      </div>
      <div class="flex flex-col">
        <div class="h-16 rounded-lg shadow-sm" style="background-color: var(--color-overlay)"></div>
        <div class="mt-2">
          <p class="text-sm font-medium" style="color: var(--color-foreground)">Overlay</p>
          <p class="text-xs font-mono" style="color: var(--color-muted-foreground)">--color-overlay</p>
        </div>
      </div>
    </div>
  </section>

  <section class="flex flex-col gap-6 mt-10">
    <h2 class="h3">Primary & Secondary</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
      <div class="flex flex-col">
        <div class="h-16 rounded-lg shadow-sm" style="background-color: var(--color-primary)"></div>
        <div class="mt-2">
          <p class="text-sm font-medium" style="color: var(--color-foreground)">Primary</p>
          <p class="text-xs font-mono" style="color: var(--color-muted-foreground)">--color-primary</p>
        </div>
      </div>
      <div class="flex flex-col">
        <div class="h-16 rounded-lg shadow-sm" style="background-color: var(--color-primary-hover)"></div>
        <div class="mt-2">
          <p class="text-sm font-medium" style="color: var(--color-foreground)">Primary Hover</p>
          <p class="text-xs font-mono" style="color: var(--color-muted-foreground)">--color-primary-hover</p>
        </div>
      </div>
      <div class="flex flex-col">
        <div class="h-16 rounded-lg shadow-sm border" style="background-color: var(--color-primary-foreground); border-color: var(--color-border)"></div>
        <div class="mt-2">
          <p class="text-sm font-medium" style="color: var(--color-foreground)">Primary FG</p>
          <p class="text-xs font-mono" style="color: var(--color-muted-foreground)">--color-primary-foreground</p>
        </div>
      </div>
      <div class="flex flex-col">
        <div class="h-16 rounded-lg shadow-sm" style="background-color: var(--color-secondary)"></div>
        <div class="mt-2">
          <p class="text-sm font-medium" style="color: var(--color-foreground)">Secondary</p>
          <p class="text-xs font-mono" style="color: var(--color-muted-foreground)">--color-secondary</p>
        </div>
      </div>
      <div class="flex flex-col">
        <div class="h-16 rounded-lg shadow-sm" style="background-color: var(--color-secondary-foreground)"></div>
        <div class="mt-2">
          <p class="text-sm font-medium" style="color: var(--color-foreground)">Secondary FG</p>
          <p class="text-xs font-mono" style="color: var(--color-muted-foreground)">--color-secondary-foreground</p>
        </div>
      </div>
      <div class="flex flex-col">
        <div class="h-16 rounded-lg shadow-sm" style="background-color: var(--color-ring)"></div>
        <div class="mt-2">
          <p class="text-sm font-medium" style="color: var(--color-foreground)">Ring</p>
          <p class="text-xs font-mono" style="color: var(--color-muted-foreground)">--color-ring</p>
        </div>
      </div>
    </div>
  </section>

  <section class="flex flex-col gap-6 mt-10">
    <h2 class="h3">Status Colors</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="flex flex-col gap-3">
        <h4 class="font-semibold" style="color: var(--color-foreground)">Destructive</h4>
        <div class="grid grid-cols-3 gap-2">
          <div class="flex flex-col">
            <div class="h-12 rounded-lg" style="background-color: var(--color-destructive)"></div>
            <p class="text-xs font-mono mt-1" style="color: var(--color-muted-foreground)">destructive</p>
          </div>
          <div class="flex flex-col">
            <div class="h-12 rounded-lg border" style="background-color: var(--color-destructive-soft); border-color: var(--color-destructive-border)"></div>
            <p class="text-xs font-mono mt-1" style="color: var(--color-muted-foreground)">soft</p>
          </div>
          <div class="flex flex-col">
            <div class="h-12 rounded-lg" style="background-color: var(--color-destructive-soft-foreground)"></div>
            <p class="text-xs font-mono mt-1" style="color: var(--color-muted-foreground)">soft-fg</p>
          </div>
        </div>
      </div>
      <div class="flex flex-col gap-3">
        <h4 class="font-semibold" style="color: var(--color-foreground)">Success</h4>
        <div class="grid grid-cols-3 gap-2">
          <div class="flex flex-col">
            <div class="h-12 rounded-lg" style="background-color: var(--color-success)"></div>
            <p class="text-xs font-mono mt-1" style="color: var(--color-muted-foreground)">success</p>
          </div>
          <div class="flex flex-col">
            <div class="h-12 rounded-lg border" style="background-color: var(--color-success-soft); border-color: var(--color-success-border)"></div>
            <p class="text-xs font-mono mt-1" style="color: var(--color-muted-foreground)">soft</p>
          </div>
          <div class="flex flex-col">
            <div class="h-12 rounded-lg" style="background-color: var(--color-success-soft-foreground)"></div>
            <p class="text-xs font-mono mt-1" style="color: var(--color-muted-foreground)">soft-fg</p>
          </div>
        </div>
      </div>
      <div class="flex flex-col gap-3">
        <h4 class="font-semibold" style="color: var(--color-foreground)">Warning</h4>
        <div class="grid grid-cols-3 gap-2">
          <div class="flex flex-col">
            <div class="h-12 rounded-lg" style="background-color: var(--color-warning)"></div>
            <p class="text-xs font-mono mt-1" style="color: var(--color-muted-foreground)">warning</p>
          </div>
          <div class="flex flex-col">
            <div class="h-12 rounded-lg border" style="background-color: var(--color-warning-soft); border-color: var(--color-warning-border)"></div>
            <p class="text-xs font-mono mt-1" style="color: var(--color-muted-foreground)">soft</p>
          </div>
          <div class="flex flex-col">
            <div class="h-12 rounded-lg" style="background-color: var(--color-warning-soft-foreground)"></div>
            <p class="text-xs font-mono mt-1" style="color: var(--color-muted-foreground)">soft-fg</p>
          </div>
        </div>
      </div>
      <div class="flex flex-col gap-3">
        <h4 class="font-semibold" style="color: var(--color-foreground)">Info</h4>
        <div class="grid grid-cols-3 gap-2">
          <div class="flex flex-col">
            <div class="h-12 rounded-lg" style="background-color: var(--color-info)"></div>
            <p class="text-xs font-mono mt-1" style="color: var(--color-muted-foreground)">info</p>
          </div>
          <div class="flex flex-col">
            <div class="h-12 rounded-lg border" style="background-color: var(--color-info-soft); border-color: var(--color-info-border)"></div>
            <p class="text-xs font-mono mt-1" style="color: var(--color-muted-foreground)">soft</p>
          </div>
          <div class="flex flex-col">
            <div class="h-12 rounded-lg" style="background-color: var(--color-info-soft-foreground)"></div>
            <p class="text-xs font-mono mt-1" style="color: var(--color-muted-foreground)">soft-fg</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="flex flex-col gap-6 mt-10">
    <h2 class="h3">Builder Configuration</h2>
    <p style="color: var(--color-muted-foreground)">These base variables control the entire theme and will be adjustable in the Builder.</p>
    <div class="p-6 rounded-lg" style="background-color: var(--color-muted)">
      <pre><code>:root {
  /* Primary — main action, paste from Figma */
  --color-primary: oklch(0.55 0.245 264);
  --color-primary-foreground: oklch(1 0 0);
  /* hover/active auto-derived via relative-color-syntax */

  /* Secondary — secondary action buttons */
  --color-secondary: oklch(0.95 0.006 264);
  --color-secondary-foreground: oklch(0.21 0.006 264);

  /* Background */
  --color-background: oklch(0.985 0.003 264);
}

.dark {
  --color-primary: oklch(0.65 0.22 264);
  --color-secondary: oklch(0.24 0.014 264);
  --color-secondary-foreground: oklch(0.93 0.003 264);
  --color-background: oklch(0.13 0.014 264);
}</code></pre>
    </div>
  </section>

  <section class="flex flex-col gap-4 mt-10">
    <h2 class="h3">Component Preview</h2>
    <p style="color: var(--color-muted-foreground)">All components use semantic tokens and will adapt to theme changes.</p>
    <div class="flex flex-wrap gap-3">
      <%= ui.btn "Default Button", variant: :default %>
      <%= ui.btn "Secondary", variant: :secondary %>
      <%= ui.btn "Outline", variant: :outline %>
      <%= ui.btn "Ghost", variant: :ghost %>
      <%= ui.btn "Danger", variant: :danger %>
      <%= ui.btn "Link Style", variant: :link %>
    </div>
  </section>
</article>
